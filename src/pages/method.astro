---
import WireframeLayout from '../layouts/WireframeLayout.astro';
import PageHero from '../components/wireframe/PageHero.astro';
import Section from '../components/wireframe/Section.astro';
import Box from '../components/wireframe/Box.astro';
import Lines from '../components/wireframe/Lines.astro';
import CtaBand from '../components/wireframe/CtaBand.astro';
---
<WireframeLayout title="指導方針">
  <PageHero eyebrow="METHOD" title="指導方針" />

  <Section eyebrow="STEP 01" title="まず、基礎から積み上げる">
    <div class="wf-cols">
      <Box label="図解イメージ" h={220} />
      <Lines n={5} head={true} />
    </div>
  </Section>

  <Section eyebrow="STEP 02" title="“勉強のやり方”を教えます" alt={true}>
    <div class="wf-cols reverse">
      <Box label="Teaching vs Coaching 図解" h={220} />
      <Lines n={5} head={true} />
    </div>
  </Section>

  <Section eyebrow="STEP 03" title="だから、自立する力が身につく">
    <div class="wf-cols">
      <Box label="図解イメージ" h={220} />
      <Lines n={5} head={true} />
    </div>
  </Section>

  <CtaBand />
</WireframeLayout>
