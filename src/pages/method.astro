---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Box from '../components/Box.astro';
import Lines from '../components/Lines.astro';
import CtaBand from '../components/CtaBand.astro';
---
<BaseLayout title="指導方針">
  <PageHero eyebrow="METHOD" title="指導方針" />

  <Section eyebrow="TEACHING vs COACHING" title="“勉強のやり方”を教えます">
    <div class="wf-cols">
      <div class="wf-card"><div class="wf-subhead"></div><Lines n={4} /></div>
      <div class="wf-card"><div class="wf-subhead"></div><Lines n={4} /></div>
    </div>
  </Section>

  <Section title="1対4だからこそ自立する力がつく" alt={true}>
    <div class="wf-cols reverse">
      <Box label="図解イメージ" h={220} />
      <Lines n={5} head={true} />
    </div>
  </Section>

  <Section title="基礎から積み上げる">
    <div class="wf-cols">
      <Box label="図解イメージ" h={220} />
      <Lines n={5} head={true} />
    </div>
  </Section>

  <CtaBand />
</BaseLayout>
