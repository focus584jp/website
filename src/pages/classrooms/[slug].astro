---
import WireframeLayout from '../../layouts/WireframeLayout.astro';
import PageHero from '../../components/wireframe/PageHero.astro';
import Section from '../../components/wireframe/Section.astro';
import Box from '../../components/wireframe/Box.astro';
import Lines from '../../components/wireframe/Lines.astro';
import CtaBand from '../../components/wireframe/CtaBand.astro';
import { classrooms } from '../../data/classrooms';

export function getStaticPaths() {
  return classrooms.map((c) => ({ params: { slug: c.slug }, props: { classroom: c } }));
}
const { classroom } = Astro.props;
---
<WireframeLayout title={classroom.name}>
  <PageHero eyebrow="CLASSROOM" title={classroom.name} />

  <Section title="基本情報">
    <table class="wf-table">
      <tbody>
        <tr><th style="width:140px">エリア</th><td>{classroom.area}</td></tr>
        <tr><th>最寄駅</th><td>{classroom.nearestStation}</td></tr>
        <tr><th>住所</th><td>{classroom.address}</td></tr>
        <tr><th>電話</th><td>{classroom.tel}</td></tr>
        <tr><th>開校時間</th><td>{classroom.hours}</td></tr>
      </tbody>
    </table>
  </Section>

  <Section title="アクセス（地図）" alt={true}>
    <Box label="Googleマップ（埋め込み予定）" h={240} />
  </Section>

  <Section title="対応中学校（ローカルSEOの要）">
    <p style="color:var(--wf-muted)">{classroom.schools.join(' / ')}</p>
  </Section>

  <Section title="教室責任者 / 教室写真" alt={true}>
    <div class="wf-cols">
      <Box label="責任者の顔写真" h={200} />
      <Lines n={5} head={true} />
    </div>
    <div class="wf-grid-3" style="margin-top:20px">
      <Box label="教室写真" h={120} />
      <Box label="教室写真" h={120} />
      <Box label="教室写真" h={120} />
    </div>
  </Section>

  <CtaBand title={`${classroom.name}で無料相談・体験を受け付けています`} />
</WireframeLayout>
