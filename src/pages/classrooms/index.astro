---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PageHero from '../../components/site/PageHero.astro';
import CtaBand from '../../components/site/CtaBand.astro';
import Icon from '../../components/site/Icon.astro';
import { classrooms, stationLabel } from '../../data/classrooms';
import { u } from '../../lib/path';

// エリア（市）ごとにグルーピング。教室が増えても見出し＋グリッドで整理できる構成
const regions = [...new Set(classrooms.map((c) => c.region))];
---
<SiteLayout
  title="教室一覧｜学習塾フォーカス"
  description="学習塾フォーカスの教室一覧。千葉市（稲毛・西千葉・都賀・新検見川・稲毛海岸・蘇我・鎌取）を中心に、市川・市原・四街道の全10教室。"
>
  <PageHero eyebrow="CLASSROOMS" title="教室一覧" deco="classroom" />

  <section class="list">
    <div class="container">
      {regions.map((r) => (
        <div class="region">
          <h2>{r}</h2>
          <div class="grid">
            {classrooms.filter((c) => c.region === r).map((c) => (
              <a class="room" href={u(`/classrooms/${c.slug}`)}>
                <div class="room-main">
                  <p class="room-name">{c.name.replace(/教室$/, '')}</p>
                  <p class="room-access">{stationLabel(c)} 徒歩{c.walkMinutes}分</p>
                </div>
                <span class="ar" aria-hidden="true"><Icon name="arrow-right" size={12} stroke="#fff" strokeWidth={2.8} /></span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <CtaBand />
</SiteLayout>

<style>
  .list { background: #fff; }
  .container { max-width: 900px; margin: 0 auto; padding: clamp(40px, 6vw, 64px) 24px; }
  .region { margin-bottom: 34px; }
  h2 {
    font-family: var(--font-round); font-weight: 900; font-size: 19px; color: var(--navy);
    border-left: 4px solid var(--navy); padding-left: 12px; margin: 0 0 14px;
  }
  /* スマホ2列・PC3列のコンパクトカード（左の紺アクセントで「押せる」ことを示す） */
  .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .room {
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
    min-width: 0; background: #fff;
    border: 1px solid var(--line); border-left: 4px solid var(--navy); border-radius: 12px;
    padding: 13px 14px; text-decoration: none; box-shadow: var(--shadow-card);
    transition: border-color .2s, transform .15s;
  }
  .room:hover { border-color: var(--navy); transform: translateY(-2px); }
  .room:active { transform: translateY(0); }
  .room-name { font-family: var(--font-round); font-size: 16.5px; font-weight: 900; color: var(--ink); margin: 0; }
  .room-access { font-size: 12px; font-weight: 700; color: var(--muted); margin: 5px 0 0; white-space: nowrap; }
  .ar {
    flex: none; width: 22px; height: 22px; border-radius: 50%;
    background: var(--navy); display: grid; place-items: center;
  }
  @media (min-width: 768px) { .grid { grid-template-columns: repeat(3, 1fr); gap: 12px; } }
</style>
