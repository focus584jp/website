---
import SiteLayout from '../layouts/SiteLayout.astro';
import PageHero from '../components/site/PageHero.astro';
import LeadForm from '../components/site/LeadForm.astro';
import Icon from '../components/site/Icon.astro';
import { phone } from '../data/home';
---
<SiteLayout
  title="無料相談のお申し込み｜学習塾フォーカス"
  description="学習塾フォーカスの無料相談。今の成績や勉強に関するお悩みを、そのままお聞かせください。塾選びのポイントや体験授業のご相談など、お子さまに合う塾探しを一緒にお手伝いします。無理な勧誘は一切いたしません。"
  fixedCta={false}
>
  <PageHero eyebrow="CONSULT" title="無料相談のお申し込み" deco="consult" />

  <section class="body">
    <div class="container">
      <LeadForm variant="consult" />

      <div class="tel-block">
        <p class="tel-label">お電話でのお申し込みはこちら</p>
        <a href={phone.tel} class="tel-num">
          <Icon name="phone" size={20} stroke="#E67832" strokeWidth={2.2} />
          {phone.display}
        </a>
        <p class="tel-hours">{phone.hours}</p>
      </div>
    </div>
  </section>
</SiteLayout>

<style>
  .body { background: #fff; }
  .container { max-width: 720px; margin: 0 auto; padding: clamp(36px, 5vw, 56px) 24px; }

  .tel-block { text-align: center; margin-top: 34px; }
  .tel-label { font-size: 14px; font-weight: 700; color: var(--ink); margin: 0; }
  .tel-num {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px; margin-top: 6px;
    font-family: var(--font-tel); font-size: clamp(26px, 5.5vw, 30px); font-weight: 800;
    letter-spacing: .02em; color: var(--navy); text-decoration: none;
  }
  .tel-hours { font-size: 12.5px; color: var(--muted); margin: 4px 0 0; }
</style>
