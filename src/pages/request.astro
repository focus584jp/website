---
import SiteLayout from '../layouts/SiteLayout.astro';
import PageHero from '../components/site/PageHero.astro';
import LeadForm from '../components/site/LeadForm.astro';
import ArrowCircle from '../components/site/ArrowCircle.astro';
import { u } from '../lib/path';
import { ctaLabels } from '../data/home';
---
<SiteLayout
  title="資料ダウンロード｜学習塾フォーカス"
  description="学習塾フォーカスのWEBパンフレットを無料でお送りします。携帯電話番号だけで、スマホに今すぐ届きます。"
  fixedCta={false}
>
  <PageHero eyebrow="REQUEST" title="資料ダウンロード" deco="request" />

  <section class="body">
    <div class="container">
      <LeadForm variant="request" />
    </div>
  </section>

  <section class="consult-lead">
    <div class="container">
      <h2>直接お話を聞きたい方へ</h2>
      <p>資料だけでなく、お子さまの状況を相談したい方は、無料相談もどうぞ。塾選びのポイントから一緒にお手伝いする気軽な面談です。</p>
      <a href={u('/consult')} class="btn3d btn3d-n consult-btn">{ctaLabels.consult}<ArrowCircle /></a>
    </div>
  </section>
</SiteLayout>

<style>
  .body { background: #fff; }
  .container { max-width: 720px; margin: 0 auto; padding: clamp(36px, 5vw, 56px) 24px; }

  .consult-lead { background: var(--alt-bg); text-align: center; }
  .consult-lead h2 { font-family: var(--font-round); font-weight: 900; font-size: clamp(19px, 2.6vw, 23px); color: var(--ink); margin: 0 0 12px; }
  .consult-lead p { font-size: 15px; line-height: 2; color: var(--ink); margin: 0 auto 20px; max-width: 560px; }
  .consult-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 9px;
    background: var(--navy); color: #fff; box-shadow: 0 5px 0 var(--navy-shadow);
    font-size: 15.5px; font-weight: 700; padding: 15px 34px; border-radius: 999px; text-decoration: none;
  }
</style>
