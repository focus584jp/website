---
import SiteLayout from '../layouts/SiteLayout.astro';
import PageHero from '../components/site/PageHero.astro';
import LeadForm from '../components/site/LeadForm.astro';
import { u } from '../lib/path';
---
<SiteLayout
  title="資料ダウンロード｜学習塾フォーカス"
  description="学習塾フォーカスのWEBパンフレットを無料でお送りします。面倒な住所入力は不要。携帯電話番号だけで、SMSでスマホに今すぐ届きます。"
  fixedCta={false}
>
  <PageHero
    eyebrow="REQUEST"
    title="資料ダウンロード"
    lead="面倒な住所入力は不要です。携帯電話番号だけで、WEBパンフレットがSMSでお手元のスマホへ今すぐ届きます。（約1分）"
  />

  <section class="body">
    <div class="container">
      <LeadForm variant="request" />
    </div>
  </section>

  <section class="consult-lead">
    <div class="container">
      <h2>直接お話を聞きたい方へ</h2>
      <p>資料だけでなく、お子さまの状況を相談したい方は、無料相談もどうぞ。教室の雰囲気を知るための気軽な面談です。</p>
      <a href={u('/consult')} class="btn3d btn3d-n consult-btn">無料相談を申し込む<span class="circle"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#143778" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h15"></path><path d="m13 6 6 6-6 6"></path></svg></span></a>
    </div>
  </section>
</SiteLayout>

<style>
  .body { background: #fff; }
  .container { max-width: 720px; margin: 0 auto; padding: clamp(36px, 5vw, 56px) 24px; }

  .consult-lead { background: var(--alt-bg); text-align: center; }
  .consult-lead h2 { font-family: var(--font-round); font-weight: 900; font-size: clamp(19px, 2.6vw, 23px); color: var(--ink); margin: 0 0 12px; }
  .consult-lead p { font-size: 15px; line-height: 2; color: var(--ink); margin: 0 auto 20px; max-width: 560px; }
  .consult-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 9px;
    background: var(--navy); color: #fff; box-shadow: 0 5px 0 var(--navy-shadow);
    font-size: 15.5px; font-weight: 700; padding: 15px 34px; border-radius: 999px; text-decoration: none;
  }
  .circle {
    width: 20px; height: 20px; border-radius: 50%; background: #fff;
    display: flex; align-items: center; justify-content: center; flex: none;
  }
</style>
