---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Box from '../components/Box.astro';
import Lines from '../components/Lines.astro';
import CtaBand from '../components/CtaBand.astro';
---
<BaseLayout title="合格実績・生徒の声">
  <PageHero eyebrow="RESULTS" title="合格実績・生徒の声" />

  <Section eyebrow="DATA" title="定期テスト・内申アップ">
    <div class="wf-grid-3">
      <div class="wf-card" style="text-align:center"><div class="wf-bignum">＋20点</div><Lines n={1} /></div>
      <div class="wf-card" style="text-align:center"><div class="wf-bignum">92%</div><Lines n={1} /></div>
      <div class="wf-card" style="text-align:center"><div class="wf-bignum">10校舎</div><Lines n={1} /></div>
    </div>
  </Section>

  <Section title="合格実績" alt={true}>
    <Box label="合格実績イメージ/一覧" h={160} />
  </Section>

  <Section title="保護者・生徒の声">
    <div class="wf-grid-3">
      <div class="wf-card"><Box label="声/写真" h={100} /><Lines n={3} /></div>
      <div class="wf-card"><Box label="声/写真" h={100} /><Lines n={3} /></div>
      <div class="wf-card"><Box label="声/写真" h={100} /><Lines n={3} /></div>
    </div>
  </Section>

  <CtaBand />
</BaseLayout>
