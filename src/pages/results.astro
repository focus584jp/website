---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Box from '../components/Box.astro';
import Lines from '../components/Lines.astro';
import CtaBand from '../components/CtaBand.astro';
---
<BaseLayout title="保護者さまの声">
  <PageHero eyebrow="VOICE" title="保護者さまの声" />

  <Section eyebrow="DATA" title="定期テスト・内申アップ">
    <div class="wf-grid-3">
      <div class="wf-card" style="text-align:center"><div class="wf-bignum">＋20点</div><Lines n={1} /></div>
      <div class="wf-card" style="text-align:center"><div class="wf-bignum">92%</div><Lines n={1} /></div>
      <div class="wf-card" style="text-align:center"><div class="wf-bignum">10教室</div><Lines n={1} /></div>
    </div>
  </Section>

  <Section title="保護者さまの声" alt={true}>
    <div class="wf-grid-3">
      <div class="wf-card"><Box label="保護者さまの声/写真" h={100} /><Lines n={3} /></div>
      <div class="wf-card"><Box label="保護者さまの声/写真" h={100} /><Lines n={3} /></div>
      <div class="wf-card"><Box label="保護者さまの声/写真" h={100} /><Lines n={3} /></div>
      <div class="wf-card"><Box label="保護者さまの声/写真" h={100} /><Lines n={3} /></div>
      <div class="wf-card"><Box label="保護者さまの声/写真" h={100} /><Lines n={3} /></div>
      <div class="wf-card"><Box label="保護者さまの声/写真" h={100} /><Lines n={3} /></div>
    </div>
  </Section>

  <CtaBand />
</BaseLayout>
