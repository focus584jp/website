---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Box from '../components/Box.astro';
import Lines from '../components/Lines.astro';
import CtaBand from '../components/CtaBand.astro';
---
<BaseLayout title="授業料">
  <PageHero eyebrow="PRICE" title="授業料" />

  <Section eyebrow="PRICE" title="通常授業料">
    <div class="wf-cols">
      <div>
        <div class="wf-bignum">5,980円</div>
        <p style="color:var(--wf-muted);margin:4px 0 16px">1講座あたり（税抜・テキストが入ります）</p>
        <Lines n={3} />
      </div>
      <Box label="授業料イメージ" h={200} />
    </div>
  </Section>

  <Section title="5教科でも集団塾並み" alt={true}>
    <table class="wf-table">
      <thead><tr><th>受講数</th><th>月額（目安）</th><th>備考</th></tr></thead>
      <tbody>
        <tr><td>3講座</td><td>—</td><td>テキスト</td></tr>
        <tr><td>5講座</td><td>—</td><td>テキスト</td></tr>
      </tbody>
    </table>
  </Section>

  <Section title="講習・諸経費（明朗会計）">
    <div class="wf-cols">
      <div class="wf-card"><div class="wf-subhead"></div><Lines n={3} /></div>
      <div class="wf-card"><div class="wf-subhead"></div><Lines n={3} /></div>
    </div>
  </Section>

  <Section title="柔軟な受け方 / 他塾比較" alt={true}>
    <div class="wf-cols">
      <Box label="比較イメージ" h={200} />
      <Lines n={5} head={true} />
    </div>
  </Section>

  <CtaBand title="資料請求でデジタルパンフをすぐお送りします" />
</BaseLayout>
