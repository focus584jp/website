---
import WireframeLayout from '../layouts/WireframeLayout.astro';
import PageHero from '../components/wireframe/PageHero.astro';
import Section from '../components/wireframe/Section.astro';
import Box from '../components/wireframe/Box.astro';
import Lines from '../components/wireframe/Lines.astro';
import CtaBand from '../components/wireframe/CtaBand.astro';
---
<WireframeLayout title="料金">
  <PageHero eyebrow="PRICE" title="料金" />

  <Section eyebrow="PRICE" title="通常授業料">
    <div class="wf-cols">
      <div>
        <div class="wf-bignum">5,980円</div>
        <p style="color:var(--wf-muted);margin:4px 0 16px">1講座あたり（税抜・テキストが入ります）</p>
        <Lines n={3} />
      </div>
      <Box label="授業料イメージ" h={200} />
    </div>
  </Section>

  {/* 「5教科でも集団塾並み」と「他塾比較」を統合 */}
  <Section title="他塾と比べても、集団塾並み" alt={true}>
    <table class="wf-table">
      <thead><tr><th>受講数</th><th>フォーカス（月額）</th><th>他塾（個別）の目安</th></tr></thead>
      <tbody>
        <tr><td>3講座</td><td>—</td><td>—</td></tr>
        <tr><td>5講座（5教科）</td><td>—（集団塾並み）</td><td>—</td></tr>
      </tbody>
    </table>
    <p style="color:var(--wf-muted);font-size:13px;margin-top:12px">※5教科受けても集団塾と同じくらい。一般的な個別指導より大幅に安い（テキストが入ります）</p>
  </Section>

  <Section title="諸経費（明朗会計）">
    <p style="margin:0 0 14px">入会金・設備管理費・維持費は<strong>一切いただきません。</strong>他塾でかかりがちな諸経費がほとんどなく、毎月の教材費とシステム利用料のみです。（金額のテキストが入ります）</p>
    <Lines n={2} />
  </Section>

  <Section title="柔軟な受け方" alt={true}>
    <div class="wf-cols">
      <Box label="受け方イメージ" h={200} />
      <Lines n={5} head={true} />
    </div>
  </Section>

  <CtaBand title="資料請求でデジタルパンフをすぐお送りします" />
</WireframeLayout>
