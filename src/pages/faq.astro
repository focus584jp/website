---
import SiteLayout from '../layouts/SiteLayout.astro';
import PageHero from '../components/site/PageHero.astro';
import FaqList from '../components/site/FaqList.astro';
import CtaBand from '../components/site/CtaBand.astro';
import { faqs } from '../data/faqs';
---
<SiteLayout
  title="よくあるご質問｜学習塾フォーカス"
  description="学習塾フォーカスによく寄せられるご質問と回答。料金・諸経費・講師・1対4の指導スタイル・部活との両立などにお答えします。"
>
  <PageHero eyebrow="FAQ" title="よくあるご質問" deco="faq" />
  <section class="body">
    <div class="container">
      <FaqList faqs={faqs} />
      <p class="note">ここにないご質問は、お電話または無料相談でお気軽にお尋ねください。</p>
    </div>
  </section>
  <CtaBand />
</SiteLayout>

<style>
  .body { background: #fff; }
  .container { max-width: 680px; margin: 0 auto; padding: clamp(40px, 6vw, 64px) 24px; }
  .note { font-size: 14px; color: var(--muted); text-align: center; margin: 22px 0 0; }
</style>
