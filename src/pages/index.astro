---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Box from '../components/Box.astro';
import Lines from '../components/Lines.astro';
import CtaBand from '../components/CtaBand.astro';
import '../styles/hero-preview.css';
import { classrooms } from '../data/classrooms';

const regions = [...new Set(classrooms.map((c) => c.region))];
---
<BaseLayout title="トップ">
  {/* ヒーロー：横スクロールのカルーセル（個別指導キャンパス参考）。数秒ごとに自動で横送り＋スワイプ可 */}
  <section class="heroB">
    <div class="hero-viewport">
      <div class="hero-track" id="heroTrack">
        {/* スライド1：メインメッセージ */}
        <div class="hero-slide">
          <div class="wrap">
            <div>
              <h1>勉強が苦手な<br />中学生専門の塾。</h1>
              <p class="sub">「どこが分からないかも分からない」、そんな子に寄り添います。</p>
              <div class="pricecard">
                <span class="lbl">1教科 月</span>
                <span class="big">5,980</span>
                <span class="unit">円〜（税抜）</span>
              </div>
            </div>
            <div class="photo">写真（先生と生徒）プレースホルダー</div>
          </div>
        </div>
        {/* スライド2：塾の選び方（相性診断） */}
        <div class="hero-slide">
          <div class="wrap">
            <div>
              <p class="lead">GUIDE</p>
              <h1>塾の選び方。</h1>
              <p class="sub">お子さまに合う塾か、相性診断でチェックできます。</p>
              <a class="btn btn-secondary" href="/choose">相性診断をしてみる</a>
            </div>
            <div class="photo">診断図/比較イメージ プレースホルダー</div>
          </div>
        </div>
      </div>
    </div>
    <button class="hero-arrow hero-prev" id="heroPrev" type="button" aria-label="前のスライド">‹</button>
    <button class="hero-arrow hero-next" id="heroNext" type="button" aria-label="次のスライド">›</button>
    <div class="hero-dots" id="heroDots">
      <button class="dot is-active" type="button" aria-label="スライド1"></button>
      <button class="dot" type="button" aria-label="スライド2"></button>
    </div>
  </section>
  <script>
    const vp = document.querySelector('.hero-viewport');
    const track = document.getElementById('heroTrack');
    const dots = Array.from(document.querySelectorAll('#heroDots .dot'));
    const prevBtn = document.getElementById('heroPrev');
    const nextBtn = document.getElementById('heroNext');
    if (vp && track && dots.length) {
      const n = dots.length;
      const reals = Array.from(track.children);
      // 前後にクローンを足して無限ループ（前進で1枚目に戻る）
      track.appendChild(reals[0].cloneNode(true));
      track.insertBefore(reals[n - 1].cloneNode(true), reals[0]);
      let pos = 1; // 本物の先頭（先頭クローンの次）
      let auto;
      const w = () => vp.clientWidth;
      const setX = (animate) => {
        track.style.transition = animate ? 'transform .5s ease' : 'none';
        track.style.transform = `translateX(${-pos * w()}px)`;
      };
      const update = () => {
        const real = ((pos - 1) % n + n) % n;
        dots.forEach((d, k) => d.classList.toggle('is-active', k === real));
      };
      const go = (dir) => { pos += dir; setX(true); update(); };
      track.addEventListener('transitionend', () => {
        if (pos === n + 1) { pos = 1; setX(false); }       // 末尾クローン→本物の1枚目へ瞬間移動
        else if (pos === 0) { pos = n; setX(false); }       // 先頭クローン→本物の最終へ
      });
      const stopAuto = () => clearInterval(auto);
      nextBtn && nextBtn.addEventListener('click', () => { stopAuto(); go(1); });
      prevBtn && prevBtn.addEventListener('click', () => { stopAuto(); go(-1); });
      dots.forEach((d, k) => d.addEventListener('click', () => { stopAuto(); pos = k + 1; setX(true); update(); }));
      // 簡易スワイプ
      let x0 = null;
      vp.addEventListener('pointerdown', (e) => { x0 = e.clientX; stopAuto(); });
      vp.addEventListener('pointerup', (e) => {
        if (x0 === null) return;
        const dx = e.clientX - x0; x0 = null;
        if (Math.abs(dx) > 40) go(dx < 0 ? 1 : -1);
      });
      window.addEventListener('resize', () => setX(false));
      setX(false);
      auto = setInterval(() => go(1), 4500);
    }
  </script>

  {/* ヒーロー直下の番号付き導線（伊藤塾参考・PC/SP共通） */}
  <nav class="wf-indexnav">
    <div class="inner">
      <a href="#reason"><span class="num">01</span>選ばれる理由</a>
      <a href="#method"><span class="num">02</span>指導方針</a>
      <a href="#price"><span class="num">03</span>料金</a>
      <a href="#results"><span class="num">04</span>保護者さまの声</a>
      <a href="#classrooms"><span class="num">05</span>教室一覧</a>
    </div>
  </nav>

  {/* こんな悩みありませんか？（3つまで） */}
  <Section eyebrow="CHECK" title="こんなお悩みありませんか？">
    <ul class="wf-check">
      <li>テキストが入ります（例：家で勉強しない）</li>
      <li>テキストが入ります（例：勉強のやり方が分からない）</li>
      <li>テキストが入ります（例：平均点が取れない）</li>
    </ul>
  </Section>

  {/* 選ばれる理由 3本柱 */}
  <Section id="reason" eyebrow="REASON" title="選ばれる理由" alt={true}>
    <div class="wf-grid-3">
      <div class="wf-card"><Box label="アイコン/画像" h={120} /><div class="wf-subhead"></div><Lines n={3} /></div>
      <div class="wf-card"><Box label="アイコン/画像" h={120} /><div class="wf-subhead"></div><Lines n={3} /></div>
      <div class="wf-card"><Box label="アイコン/画像" h={120} /><div class="wf-subhead"></div><Lines n={3} /></div>
    </div>
    <p style="text-align:center;margin-top:28px"><a class="wf-btn wf-btn-ghost" href="/reason">詳しく見る</a></p>
  </Section>

  {/* 料金（指導方針と同じレイアウト：詳細ページへ誘導。資料請求ボタンは置かない） */}
  <Section id="price" eyebrow="PRICE" title="料金" alt={true}>
    <div class="wf-cols">
      <div>
        <div class="wf-bignum">5,980円〜</div>
        <p style="color:var(--wf-muted);margin:4px 0 14px">1教科あたり（テキストが入ります）</p>
        <Lines n={3} />
        <p style="margin-top:18px;text-align:center"><a class="wf-btn wf-btn-ghost" href="/price">詳しく見る</a></p>
      </div>
      <Box label="料金イメージ/比較" h={220} />
    </div>
  </Section>

  {/* 指導方針 */}
  <Section id="method" eyebrow="METHOD" title="指導方針">
    <div class="wf-cols">
      <Box label="指導イメージ" h={220} />
      <div>
        <Lines n={5} head={true} />
        <p style="margin-top:18px;text-align:center"><a class="wf-btn wf-btn-ghost" href="/method">詳しく見る</a></p>
      </div>
    </div>
  </Section>

  {/* 保護者さまの声：横スクロールで複数件（ページ化はしない） */}
  <Section id="results" eyebrow="VOICE" title="保護者さまの声" alt={true}>
    <div class="wf-hscroll">
      <div class="wf-card"><Box label="保護者さまの声/写真" h={120} /><Lines n={3} /></div>
      <div class="wf-card"><Box label="保護者さまの声/写真" h={120} /><Lines n={3} /></div>
      <div class="wf-card"><Box label="保護者さまの声/写真" h={120} /><Lines n={3} /></div>
      <div class="wf-card"><Box label="保護者さまの声/写真" h={120} /><Lines n={3} /></div>
      <div class="wf-card"><Box label="保護者さまの声/写真" h={120} /><Lines n={3} /></div>
    </div>
    <p style="color:var(--wf-muted);font-size:13px;text-align:center;margin-top:14px">← 横にスクロールできます →</p>
  </Section>

  {/* 教室（エリアから探す：教室数が増えても崩れない構成） */}
  <Section id="classrooms" eyebrow="CLASSROOMS" title="教室一覧">
    <Box label="エリアマップ（教室をプロット）" h={200} />
    <div class="wf-region-chips" style="margin-top:20px">
      {regions.map((r) => <a class="wf-chip" href="/classrooms">{r}</a>)}
    </div>
    <p style="text-align:center;margin-top:24px"><a class="wf-btn wf-btn-ghost" href="/classrooms">教室一覧を見る</a></p>
  </Section>

  {/* 入塾までの流れ */}
  <Section eyebrow="FLOW" title="入塾までの流れ">
    <div class="wf-steps">
      <div class="wf-step"><div class="num">1</div><div class="wf-subhead" style="margin:0 auto 10px;width:70%"></div><Lines n={2} /></div>
      <div class="wf-step"><div class="num">2</div><div class="wf-subhead" style="margin:0 auto 10px;width:70%"></div><Lines n={2} /></div>
      <div class="wf-step"><div class="num">3</div><div class="wf-subhead" style="margin:0 auto 10px;width:70%"></div><Lines n={2} /></div>
      <div class="wf-step"><div class="num">4</div><div class="wf-subhead" style="margin:0 auto 10px;width:70%"></div><Lines n={2} /></div>
    </div>
  </Section>

  {/* FAQ抜粋 */}
  <Section eyebrow="FAQ" title="よくあるご質問" alt={true}>
    <div class="wf-rows">
      <div class="wf-row"><span class="bar"></span><span class="plus">＋</span></div>
      <div class="wf-row"><span class="bar"></span><span class="plus">＋</span></div>
      <div class="wf-row"><span class="bar"></span><span class="plus">＋</span></div>
    </div>
    <p style="text-align:center;margin-top:24px"><a class="wf-btn wf-btn-ghost" href="/faq">よくある質問をすべて見る</a></p>
  </Section>

  <CtaBand />
</BaseLayout>
