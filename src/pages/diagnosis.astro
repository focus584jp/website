import SiteLayout from '../layouts/SiteLayout.astro';
import DiagnosisApp from '../components/site/DiagnosisApp.astro';
---
<SiteLayout
  title="30秒でわかる塾タイプ診断｜学習塾フォーカス"
  description="お子さまのことを5問だけ教えてください。集団指導・個別指導など、ぴったりの塾のタイプがその場で分かります。30秒・全5問の無料診断。"
  fixedCta={false}
>
  <DiagnosisApp />
</SiteLayout>
