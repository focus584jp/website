---
import SiteLayout from '../layouts/SiteLayout.astro';
import PageHero from '../components/site/PageHero.astro';
import { companyInfo, history, privacyPolicy } from '../data/company';
---
<SiteLayout
  title="会社概要｜学習塾フォーカス"
  description="学習塾フォーカス（株式会社フォーカス）の会社概要・沿革・プライバシーポリシー。"
>
  <PageHero eyebrow="COMPANY" title="会社概要" deco="company" />

  <section class="sec">
    <div class="container">
      <h2>会社情報</h2>
      <table>
        <tbody>
          {companyInfo.map((r) => (
            <tr>
              <th>{r.label}</th>
              <td>
                {r.items ? (
                  <ul class="cell-list">{r.items.map((i) => <li>{i}</li>)}</ul>
                ) : (
                  <span>{r.value}{r.flag && <span class="flag">{r.flag}</span>}{r.caution && <span class="cell-caution">※{r.caution}</span>}</span>
                )}
                {r.note && <span class="cell-note">{r.note}</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="note">※ 資料請求・無料相談など保護者さまのお問い合わせは、0120-267-140（受付 16:00〜22:00／日曜定休）へお願いします。</p>
    </div>
  </section>

  <section class="sec alt">
    <div class="container">
      <h2>沿革</h2>
      <div class="timeline">
        {history.map((h) => (
          <div class="tl-item">
            <div class="tl-date">{h.date}</div>
            <div class="tl-body">
              {h.events.map((e) => <p>{e}</p>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="sec" id="privacy">
    <div class="container">
      <h2>プライバシーポリシー</h2>
      {privacyPolicy.map((s) => (
        <div class="clause">
          {s.heading && <h3>{s.heading}</h3>}
          {s.paragraphs?.map((p) => <p class="body-text">{p}</p>)}
          {s.items && (
            <ul class="list">
              {s.items.map((i) => <li>{i}</li>)}
            </ul>
          )}
        </div>
      ))}
    </div>
  </section>
</SiteLayout>

<style>
  .sec { background: #fff; }
  .sec.alt { background: var(--alt-bg); }
  .container { max-width: 720px; margin: 0 auto; padding: clamp(40px, 6vw, 60px) 24px; }
  h2 {
    font-family: var(--font-round); font-weight: 900; font-size: 19px; color: var(--navy);
    border-left: 4px solid var(--navy); padding-left: 12px; margin: 0 0 16px;
  }

  /* 会社情報テーブル */
  table { width: 100%; border-collapse: collapse; }
  th, td { border: 1px solid var(--line); padding: 13px 16px; font-size: 14.5px; color: var(--ink); text-align: left; vertical-align: top; }
  th { background: var(--alt-bg); font-weight: 700; width: 108px; white-space: nowrap; }
  .cell-list { margin: 0; padding-left: 1.3em; }
  .cell-list li { line-height: 1.9; }
  .cell-note { display: block; margin-top: 6px; font-size: 12px; color: var(--gray-1); line-height: 1.7; }
  .cell-caution { margin-left: 8px; font-size: 12px; font-weight: 700; color: #C0392B; }
  @media (max-width: 767px) {
    .cell-caution { display: block; margin-left: 0; margin-top: 5px; line-height: 1.7; }
  }
  .flag {
    display: inline-block; margin-left: 8px; font-size: 11px; font-weight: 700;
    color: #C0392B; background: #FDECEC; padding: 2px 8px; border-radius: 999px; vertical-align: middle;
  }
  .note { font-size: 12px; color: var(--gray-1); margin: 12px 0 0; line-height: 1.7; }

  /* 沿革タイムライン */
  .timeline { display: flex; flex-direction: column; }
  .tl-item { display: grid; grid-template-columns: 84px 1fr; gap: 16px; }
  .tl-date {
    font-size: 13px; font-weight: 700; color: var(--navy); white-space: nowrap;
    text-align: right; padding-bottom: 22px; font-variant-numeric: tabular-nums;
  }
  .tl-body {
    position: relative; padding: 0 0 22px 22px;
  }
  .tl-body::before {  /* 縦線 */
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 2px; background: var(--blue-pale); transform: translateX(-50%);
  }
  .tl-body::after {  /* 紺ドット（地色フチ＋淡青リング） */
    content: ''; position: absolute; left: 0; top: 5px; width: 11px; height: 11px;
    border-radius: 50%; background: var(--navy); transform: translateX(-50%);
    box-shadow: 0 0 0 3px var(--alt-bg), 0 0 0 4.5px var(--blue-pale);
  }
  .tl-item:last-child .tl-body::before { bottom: auto; height: 10px; }
  .tl-item:last-child .tl-body { padding-bottom: 0; }
  .tl-body p { margin: 0 0 4px; font-size: 14px; line-height: 1.8; color: var(--ink); }
  .tl-body p:last-child { margin-bottom: 0; }

  /* プライバシーポリシー */
  .clause { margin-bottom: 22px; }
  .clause:last-of-type { margin-bottom: 0; }
  h3 {
    font-family: var(--font-round); font-weight: 700; font-size: 15.5px; color: var(--ink);
    margin: 0 0 8px;
  }
  .body-text { font-size: 14.5px; line-height: 2; color: var(--ink); margin: 0 0 6px; }
  .body-text:last-child { margin-bottom: 0; }
  .list { margin: 6px 0 0; padding-left: 1.4em; }
  .list li { font-size: 14.5px; line-height: 1.9; color: var(--ink); }
</style>
