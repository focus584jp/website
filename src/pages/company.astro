---
import WireframeLayout from '../layouts/WireframeLayout.astro';
import PageHero from '../components/wireframe/PageHero.astro';
import Section from '../components/wireframe/Section.astro';
import Box from '../components/wireframe/Box.astro';
import Lines from '../components/wireframe/Lines.astro';
---
<WireframeLayout title="会社概要">
  <PageHero eyebrow="COMPANY" title="会社概要" />

  <Section title="会社情報">
    <table class="wf-table">
      <tbody>
        <tr><th style="width:160px">運営会社</th><td>—</td></tr>
        <tr><th>所在地</th><td>—</td></tr>
        <tr><th>設立</th><td>—</td></tr>
        <tr><th>事業内容</th><td>—</td></tr>
      </tbody>
    </table>
  </Section>

  <Section title="代表挨拶" alt={true}>
    <div class="wf-cols">
      <Box label="代表写真" h={200} />
      <Lines n={6} head={true} />
    </div>
  </Section>

  <Section title="講師採用方針（千葉大生のみ）">
    <Lines n={4} />
  </Section>

  <Section title="プライバシーポリシー / 特定商取引法に基づく表記" alt={true}>
    <Lines n={5} />
  </Section>
</WireframeLayout>
