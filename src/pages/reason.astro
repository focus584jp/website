---
import { Image } from 'astro:assets';
import SiteLayout from '../layouts/SiteLayout.astro';
import PageHero from '../components/site/PageHero.astro';
import CtaBand from '../components/site/CtaBand.astro';
import reason1 from '../assets/home/reason-1.jpg';
import reason2 from '../assets/home/reason-2.jpg';
import reason3 from '../assets/home/reason-3.jpg';
import { u } from '../lib/path';

const points = [
  {
    num: '01', img: reason1, alt: '生徒に寄り添って教える先生',
    title: '「勉強が苦手」な中学生専門',
    body: [
      '「どこが分からないかも分からない…」。フォーカスに来る生徒の多くが、最初はそう感じています。だからこそ私たちは、学校の進度に無理に合わせません。まず、お子さまがつまずいた場所を一緒に探すところから始めます。',
      '中学の勉強でつまずく原因の多くは、その手前の単元の「取りこぼし」です。基礎まで戻って積み上げ直すから、「わからない」が「わかる！」に変わり、成績が確実に伸びていきます。',
    ],
    link: { href: '/method', label: '指導方針を詳しく見る' },
  },
  {
    num: '02', img: reason2, alt: '安心した表情で料金明細を見る母親',
    title: '個別指導の常識を破る「低価格」',
    body: [
      '個別指導を、1教科あたり月6,578円（税込）の安心価格で実現しました。入会金・設備管理費などの諸経費は0円。授業料は中学3年間据え置きです。',
      '成績を上げるには、続けることがいちばん大切です。家計に無理のない料金だから、教科を増やしても、受験まで長く通い続けることができます。',
    ],
    link: { href: '/price', label: '料金を詳しく見る' },
  },
  {
    num: '03', img: reason3, alt: '笑顔の千葉大生講師たち',
    title: '講師は全員「千葉大生」',
    body: [
      'フォーカスの講師は、厳選された現役の千葉大生だけ。どの教室・どの授業でも、質の高い指導をお約束できます。担当によるムラがなく、お子さまの学力を着実に引き上げます。',
      '年の近いお兄さん・お姉さんのような存在だから、質問もしやすく、「先生に会いに行くのが楽しみ」と塾に通うこと自体が続く理由になります。',
    ],
  },
];
---
<SiteLayout
  title="選ばれる理由｜学習塾フォーカス"
  description="学習塾フォーカスが選ばれる3つの理由。勉強が苦手な中学生専門・月6,578円（税込）の低価格・講師は全員千葉大生。"
>
  <PageHero
    eyebrow="REASON"
    title="フォーカスが選ばれる理由"
    lead="勉強が苦手なお子さまの保護者さまに、フォーカスが選ばれ続けている理由は3つあります。"
  />

  {points.map((p, i) => (
    <section class:list={['point', { alt: i % 2 === 1 }]}>
      <div class="container">
        <div class:list={['cols', { reverse: i % 2 === 1 }]}>
          <div class="img-wrap">
            <Image src={p.img} alt={p.alt} widths={[480, 960]} sizes="(max-width: 767px) 92vw, 460px" class="photo" />
          </div>
          <div class="text">
            <p class="point-label">POINT {p.num}</p>
            <h2>{p.title}</h2>
            {p.body.map((t) => <p class="body-text">{t}</p>)}
            {p.link && (
              <a href={u(p.link.href)} class="btn-out more">{p.link.label}<span class="ar">→</span></a>
            )}
          </div>
        </div>
      </div>
    </section>
  ))}

  <CtaBand />
</SiteLayout>

<style>
  .point { background: #fff; }
  .point.alt { background: var(--alt-bg); }
  .container { max-width: 1000px; margin: 0 auto; padding: clamp(44px, 6vw, 72px) 24px; }
  .cols { display: flex; flex-direction: column; gap: 26px; align-items: center; }
  .img-wrap { width: 100%; max-width: 460px; }
  .photo { width: 100%; height: auto; border-radius: 14px; box-shadow: var(--shadow-card); display: block; }
  .text { max-width: 560px; }
  .point-label { font: 800 13px var(--font-round); color: var(--orange-shadow); letter-spacing: .28em; margin: 0 0 8px; }
  h2 { font-family: var(--font-round); font-weight: 900; font-size: clamp(21px, 3vw, 26px); color: var(--ink); margin: 0 0 14px; }
  .body-text { font-size: 15px; line-height: 2; color: var(--ink); margin: 0 0 12px; }
  .more {
    display: inline-flex; align-items: center; gap: 8px; margin-top: 6px;
    border: 2px solid var(--navy); color: var(--navy); background: #fff;
    font-size: 14.5px; font-weight: 700; padding: 12px 26px; border-radius: 999px; text-decoration: none;
  }

  @media (min-width: 768px) {
    .cols { flex-direction: row; gap: 44px; }
    .cols.reverse { flex-direction: row-reverse; }
    .img-wrap { flex: 0 0 44%; }
    .text { flex: 1; }
  }
</style>
