---
import WireframeLayout from '../layouts/WireframeLayout.astro';
import PageHero from '../components/wireframe/PageHero.astro';
import Section from '../components/wireframe/Section.astro';
import Box from '../components/wireframe/Box.astro';
import Lines from '../components/wireframe/Lines.astro';
import CtaBand from '../components/wireframe/CtaBand.astro';
---
<WireframeLayout title="選ばれる理由">
  <PageHero eyebrow="REASON" title="フォーカスが選ばれる理由" />

  <Section eyebrow="POINT 01" title="勉強が苦手な子“専門”">
    <div class="wf-cols">
      <Box label="イメージ" h={220} />
      <Lines n={5} head={true} />
    </div>
  </Section>

  <Section eyebrow="POINT 02" title="個別指導なのに通いやすい価格" alt={true}>
    <div class="wf-cols reverse">
      <Box label="イメージ" h={220} />
      <Lines n={5} head={true} />
    </div>
  </Section>

  <Section eyebrow="POINT 03" title="講師は全員千葉大生">
    <div class="wf-cols">
      <Box label="イメージ" h={220} />
      <Lines n={5} head={true} />
    </div>
  </Section>

  <CtaBand />
</WireframeLayout>
