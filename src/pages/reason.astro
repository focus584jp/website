---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Box from '../components/Box.astro';
import Lines from '../components/Lines.astro';
import CtaBand from '../components/CtaBand.astro';
---
<BaseLayout title="選ばれる理由">
  <PageHero eyebrow="REASON" title="フォーカスが選ばれる理由" />

  <Section eyebrow="POINT 01" title="勉強が苦手な子専門">
    <div class="wf-cols">
      <Box label="イメージ" h={220} />
      <Lines n={5} head={true} />
    </div>
  </Section>

  <Section eyebrow="POINT 02" title="個別指導なのに通いやすい価格" alt={true}>
    <div class="wf-cols reverse">
      <Box label="イメージ" h={220} />
      <Lines n={5} head={true} />
    </div>
  </Section>

  <Section eyebrow="POINT 03" title="講師は全員千葉大生">
    <div class="wf-cols">
      <Box label="イメージ" h={220} />
      <Lines n={5} head={true} />
    </div>
  </Section>

  <CtaBand />
</BaseLayout>
