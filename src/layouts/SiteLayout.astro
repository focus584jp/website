---
// hifi化したページ用のレイアウト（ワイヤー用 WireframeLayout とは別系統）
// フォントは自己ホスト（fontsource）: レンダリングブロック回避のためGoogle Fonts外部CSSは使わない
import '@fontsource-variable/noto-sans-jp';
import '@fontsource/zen-maru-gothic/japanese-700.css';
import '@fontsource/zen-maru-gothic/japanese-900.css';
import '../styles/site.css';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';
import FixedCta from '../components/site/FixedCta.astro';
import DiagnosisPopup from '../components/site/DiagnosisPopup.astro';
import { u } from '../lib/path';

const { title, description = '' } = Astro.props;
// OGP用の絶対URL（LINE・SNS共有時に必須）
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(u('/ogp.jpg'), Astro.site).href;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />{/* 公開前：検索インデックス除外。ローンチ時に外す */}
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href={u('/favicon.svg')} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="FOCUS（フォーカス）" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <SiteHeader />
    <main><slot /></main>
    <SiteFooter />
    <FixedCta />
    <DiagnosisPopup />

    <script>
      // ヒーロー通過判定 → body.past-hero（PC右端CTA・診断ポップアップの表示トリガー）
      const hero = document.getElementById('top');
      function onScroll() {
        const past = hero ? hero.getBoundingClientRect().bottom < 70 : window.scrollY > 400;
        document.body.classList.toggle('past-hero', past);
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // 初回ペイントのチラつき防止: CSS適用後にPC右端CTAのインライン非表示を解除
      const sideCta = document.querySelector<HTMLElement>('[data-side-cta]');
      requestAnimationFrame(() => sideCta?.style.removeProperty('visibility'));

      // タッチでの「沈み込み」フィードバック（:hoverが効かない環境向け）
      window.addEventListener('pointerdown', (e) => {
        (e.target as Element | null)?.closest?.('.btn3d')?.classList.add('pressed');
      }, true);
      const release = () => document.querySelectorAll('.btn3d.pressed').forEach((b) => b.classList.remove('pressed'));
      window.addEventListener('pointerup', release, true);
      window.addEventListener('pointercancel', release, true);
    </script>
  </body>
</html>
