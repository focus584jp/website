---
// フッター（ワイヤー）。教室への電話を常設し、全ページから問い合わせできるように。
const TEL = '0120-000-000'; // 代表ダミー。各教室直通は教室ページに掲載
---
<footer class="wf-footer">
  <div class="wf-container">
    {/* 電話導線（全ページ共通） */}
    <div class="wf-footer-tel">
      <span class="label">お電話でのお問い合わせ</span>
      <a class="num" href={`tel:${TEL.replace(/-/g, '')}`}>{TEL}</a>
      <span class="note">（各教室直通は<a href="/classrooms">教室一覧</a>から）</span>
    </div>

    <div class="cols">
      <div>
        <a class="wf-logo" href="/">ロゴ</a>
        <div class="wf-lines"><span style="width:100%"></span><span style="width:80%"></span></div>
      </div>
      <div>
        <a href="/reason">選ばれる理由</a>
        <a href="/price">料金</a>
        <a href="/classrooms">教室一覧</a>
        <a href="/faq">よくある質問</a>
      </div>
      <div>
        <a href="/document">資料請求</a>
        <a href="/consult">無料相談</a>
        <a href="/company">会社概要</a>
        <a href="/company">プライバシーポリシー</a>
        <a href="/company">特定商取引法に基づく表記</a>
      </div>
    </div>
    <div class="copy">© FOCUS（仮）</div>
  </div>
</footer>
