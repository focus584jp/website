---
// よくあるご質問（トップ掲載3問＋全件への導線）
import SectionHead from '../site/SectionHead.astro';
import FaqList from '../site/FaqList.astro';
import { faqs } from '../../data/faqs';
import { u } from '../../lib/path';
---
<section id="faq" class="faq">
  <div class="container">
    <SectionHead eyebrow="FAQ" title="よくあるご質問" />
    <FaqList faqs={faqs.filter((f) => f.top)} />
    <div class="more">
      <a href={u('/faq')} class="btn-out">すべての質問を見る<span class="ar">→</span></a>
    </div>
  </div>
</section>

<style>
  .faq { background: #fff; }
  .container { max-width: 680px; margin: 0 auto; padding: clamp(48px, 7vw, 88px) 24px; }
  .more { display: flex; justify-content: center; margin-top: 24px; }
  .more a {
    display: flex; align-items: center; justify-content: center; gap: 8px; min-width: 200px;
    border: 2px solid var(--navy); color: var(--navy); background: #fff;
    font-size: 14.5px; font-weight: 700; padding: 13px 28px; border-radius: 999px; text-decoration: none;
  }
</style>
