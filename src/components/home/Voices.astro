---
// 04 保護者さまの声 — 中央拡大カルーセル（前後ボタン・カードタップ・ドット）
// ※文面は仮 — 公開前に実物へ差し替え必須。アイコンは設定済み（4番目=父親、他は母親）
import { Image } from 'astro:assets';
import SectionHead from '../site/SectionHead.astro';
import { voices } from '../../data/home';
import v1 from '../../assets/home/voices/voice-1.png';
import v2 from '../../assets/home/voices/voice-2.png';
import v3 from '../../assets/home/voices/voice-3.png';
import v4 from '../../assets/home/voices/voice-4.png';
import v5 from '../../assets/home/voices/voice-5.png';
const avatars = [v1, v2, v3, v4, v5];
---
<section id="voice" class="voice">
  <div class="container">
    <div class="head-wrap"><SectionHead eyebrow="VOICE" title="保護者さまの声" /></div>
    <div class="carousel" data-voice>
      <div class="viewport" data-voice-viewport>
        <div class="track" data-voice-track>
          {voices.map((v, i) => (
            <div class="card" data-voice-card data-index={i}>
              <div class="meta">
                <span class="avatar"><Image src={avatars[i]} alt="" width={256} height={256} class="avatar-img" loading="lazy" /></span>
                <div class="names"><span class="who">{v.who}</span><span class="draft">※仮の内容です</span></div>
              </div>
              <p>{v.text}</p>
            </div>
          ))}
        </div>
      </div>
      <button class="nav prev" aria-label="前の声へ" data-voice-prev>‹</button>
      <button class="nav next" aria-label="次の声へ" data-voice-next>›</button>
    </div>
    <div class="dots">
      {voices.map((_, i) => (
        <button aria-label={`${i + 1}件目を表示`} data-voice-dot data-index={i}></button>
      ))}
    </div>
  </div>
</section>

<style>
  .voice { background: var(--alt-bg); }
  .container { max-width: 1160px; margin: 0 auto; padding: clamp(48px, 7vw, 88px) 0; }
  .head-wrap { padding: 0 24px; }
  .carousel { position: relative; max-width: 680px; margin: 0 auto; padding: 0 24px; box-sizing: border-box; }
  .viewport { overflow: hidden; padding: 12px 0; touch-action: pan-y; cursor: grab; }
  .viewport.dragging { cursor: grabbing; }
  .viewport.dragging .card { transition: none; }
  .track { display: flex; align-items: stretch; transition: transform .45s cubic-bezier(.25, .8, .3, 1); }
  .card {
    flex: 0 0 70%; margin: 0 3%; box-sizing: border-box; background: #fff;
    border: 1px solid var(--line); border-radius: 14px; padding: 22px;
    display: flex; flex-direction: column; gap: 12px; min-height: 170px; cursor: pointer;
    transform: scale(.85); opacity: .5; transition: transform .45s, opacity .45s;
  }
  .card.active { transform: scale(1); opacity: 1; }
  .meta { display: flex; align-items: center; gap: 12px; }
  .avatar {
    position: relative; width: 64px; height: 64px; border-radius: 50%; flex: none; overflow: hidden;
    background: #F4F1EA; border: 1px solid var(--line);
  }
  /* 元画像を頭位置基準でトリミング済みなので、そのまま円に収める */
  .avatar-img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .names { display: flex; flex-direction: column; }
  .who { font-size: 14px; font-weight: 700; color: var(--ink); }
  .draft { font-size: 12px; font-weight: 700; color: #C0392B; }
  .card p { font-size: 15px; line-height: 1.9; color: var(--ink); margin: 0; }
  .nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 36px; height: 36px; border-radius: 50%; border: none;
    background: rgba(255, 255, 255, .94); color: var(--navy);
    font-size: 20px; font-weight: 900; line-height: 1; cursor: pointer;
    display: grid; place-items: center; box-shadow: 0 2px 8px rgba(29, 42, 54, .22); padding: 0 0 2px;
  }
  .prev { left: 8px; }
  .next { right: 8px; }
  /* 見た目は9pxドットのまま、タップ領域を24pxに確保 */
  .dots { display: flex; justify-content: center; margin-top: 8px; }
  .dots button {
    width: 24px; height: 24px; border: none; padding: 0; cursor: pointer;
    background: none; display: grid; place-items: center;
  }
  .dots button::after { content: ""; width: 9px; height: 9px; border-radius: 50%; background: #C6D4DF; }
  .dots button.active::after { background: var(--navy); }
</style>

<script>
  const viewport = document.querySelector<HTMLElement>('[data-voice-viewport]');
  const track = document.querySelector<HTMLElement>('[data-voice-track]');
  const cards = [...document.querySelectorAll<HTMLElement>('[data-voice-card]')];
  const dots = [...document.querySelectorAll<HTMLElement>('[data-voice-dot]')];
  let idx = 0;

  // カード幅70% + 左右マージン3%×2 = 76%ピッチ。先頭カードの中心を38%位置に置く
  const baseX = () => -(idx * 0.76 - 0.12) * (viewport?.clientWidth ?? 0);

  function render(dragPx = 0, animate = true) {
    if (!viewport || !track) return;
    track.style.transition = animate ? '' : 'none';
    track.style.transform = `translateX(${baseX() + dragPx}px)`;
    cards.forEach((c, i) => c.classList.toggle('active', i === idx));
    dots.forEach((d, i) => d.classList.toggle('active', i === idx));
  }

  function goTo(i: number) {
    idx = (i + cards.length) % cards.length;
    render();
  }

  document.querySelector('[data-voice-prev]')?.addEventListener('click', () => goTo(idx - 1));
  document.querySelector('[data-voice-next]')?.addEventListener('click', () => goTo(idx + 1));
  dots.forEach((d) => d.addEventListener('click', () => goTo(Number(d.dataset.index))));
  window.addEventListener('resize', () => render());

  // --- 横スワイプ対応（縦スクロールは touch-action: pan-y でブラウザに委ねる） ---
  let startX = 0;
  let swiped = false;
  let dragging = false;

  viewport?.addEventListener('pointerdown', (e) => {
    startX = e.clientX;
    dragging = true;
    swiped = false;
  });
  viewport?.addEventListener('pointermove', (e) => {
    if (!dragging || !viewport) return;
    const dx = e.clientX - startX;
    if (!swiped && Math.abs(dx) > 8) {
      swiped = true;
      viewport.classList.add('dragging');
      try { viewport.setPointerCapture(e.pointerId); } catch {}
    }
    if (swiped) render(dx, false);
  });
  function endSwipe(e: PointerEvent) {
    if (!dragging) return;
    dragging = false;
    viewport?.classList.remove('dragging');
    const dx = e.clientX - startX;
    if (swiped && dx <= -50) goTo(idx + 1);
    else if (swiped && dx >= 50) goTo(idx - 1);
    else render(); // しきい値未満は元の位置へ戻す
  }
  viewport?.addEventListener('pointerup', endSwipe);
  viewport?.addEventListener('pointercancel', endSwipe);

  // カードタップでそのカードへ（スワイプ直後のクリックは無視）
  cards.forEach((c) => c.addEventListener('click', () => {
    if (swiped) return;
    goTo(Number(c.dataset.index));
  }));

  render();
</script>
