---
// CTAバンド（ネイビー）— 資料DL / 無料相談 / 電話
import { phone } from '../../data/home';
import { u } from '../../lib/path';
---
<section class="cta-band">
  <div class="container">
    <h2><span class="hl">まずは、話を聞きに来ませんか？</span></h2>
    <p>無理な勧誘はいたしません。パンフだけでもお気軽に。</p>
    <div class="buttons">
      <a href={u('/document')} class="btn-shine btn3d btn3d-o doc"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v11"></path><path d="m7 10 5 5 5-5"></path><path d="M4 21h16"></path></svg>資料をダウンロード</a>
      <a href={u('/consult')} class="consult">無料相談を申し込む →</a>
      <a href={phone.tel} class="tel">お近くの教室へ電話する</a>
    </div>
  </div>
</section>

<style>
  .cta-band { background: var(--navy); }
  .container { max-width: 560px; margin: 0 auto; padding: clamp(48px, 7vw, 80px) 24px; text-align: center; }
  h2 { font-family: var(--font-round); font-weight: 900; font-size: clamp(22px, 3.2vw, 30px); color: #fff; margin: 0; }
  .hl { background: linear-gradient(transparent 62%, rgba(255, 232, 105, .4) 62% 94%, transparent 94%); padding: 0 4px; }
  p { font-size: 13.5px; color: #C9D6EE; margin: 14px 0 26px; }
  .buttons { display: flex; flex-direction: column; gap: 11px; max-width: 380px; margin: 0 auto; }
  .buttons a {
    display: flex; align-items: center; justify-content: center; gap: 9px;
    font-size: 16px; font-weight: 700; padding: 16px; border-radius: 999px; text-decoration: none;
  }
  .doc { background: var(--orange); color: #fff; box-shadow: 0 5px 0 var(--orange-shadow); }
  .consult { background: #fff; color: var(--navy); transition: transform .2s; }
  .consult:hover { transform: translateY(-2px); }
  .tel {
    background: transparent; border: 1.5px solid rgba(255, 255, 255, .45); color: #fff;
    font-size: 14.5px !important; padding: 14px !important; transition: background .2s;
  }
  .tel:hover { background: rgba(255, 255, 255, .08); }
</style>
