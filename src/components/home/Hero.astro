---
// ヒーロー: 実写写真＋白グラデ、ラベル、手書きキャッチ画像、料金カード、CTA（PCのみ。SP/タブレットは下部固定CTAが担う）
import { Image } from 'astro:assets';
import heroWide from '../../assets/home/hero-photo-crop2.jpg';
import heroNarrow from '../../assets/home/hero-photo-sp-small.png';
import heroCatch from '../../assets/home/hero-catch-small.png';
import { u } from '../../lib/path';
---
<section class="hero" id="top">
  <div class="wrap">
    <Image src={heroNarrow} alt="階段をのぼる生徒と先生" widths={[480, 736]} sizes="86vw" class="photo-narrow" loading="eager" />
    <Image src={heroWide} alt="階段をのぼる生徒と先生" widths={[768, 1100, 1500]} sizes="100vw" class="photo-wide" loading="eager" />
    <div class="fade" aria-hidden="true"></div>

    <div class="text">
      <div><span class="tag">勉強が苦手な中学生専門！</span></div>
      <h1 aria-label="「できた！」が増えると、勉強は変わる。">
        <Image src={heroCatch} alt="「できた！」が増えると、勉強は変わる。" widths={[560, 700, 1120, 1400]} sizes="(max-width: 767px) 72vw, 700px" class="catch" loading="eager" />
      </h1>
      <p class="sub"><span>一人ひとりの「わからない」に寄り添い、</span><br /><span>小さな成功体験を積み重ねます。</span></p>

      <div class="price-card">
        <div class="cell">
          <div class="label">1教科あたり</div>
          <div class="value"><span class="unit unit-l">月</span><span class="num">6,578</span><span class="unit">円<span class="tilde">〜</span></span></div>
        </div>
        <div class="v-line"></div>
        <div class="cell">
          <div class="label">入会金</div>
          <div class="value"><span class="num">0</span><span class="unit">円</span></div>
        </div>
      </div>

      <div class="cta-row">
        <a href={u('/consult')} class="btn3d btn3d-n cta-consult">無料相談を申し込む<span class="circle"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#143778" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h15"></path><path d="m13 6 6 6-6 6"></path></svg></span></a>
        <a href={u('/document')} class="btn-shine btn3d btn3d-o cta-doc"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v11"></path><path d="m7 10 5 5 5-5"></path><path d="M4 21h16"></path></svg>資料をダウンロード</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero { background: #fff; overflow: hidden; }
  .wrap {
    position: relative; max-width: 1440px; margin: 0 auto; overflow: hidden;
    display: flex; align-items: stretch; min-height: auto;
  }
  .photo-narrow { position: absolute; top: 0; right: -3%; width: 86%; height: auto; display: block; }
  .photo-wide {
    display: none; position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: right top; transform-origin: right top; transform: translateX(9%);
  }
  .fade {
    position: absolute; inset: 0;
    background:
      linear-gradient(to right, rgba(255,255,255,.88) 6%, rgba(255,255,255,.5) 44%, rgba(255,255,255,0) 72%),
      linear-gradient(to top, #fff 0%, rgba(255,255,255,0) 12%);
  }
  .text {
    position: relative; z-index: 2; box-sizing: border-box;
    width: calc(100% - 48px); max-width: none; margin-left: 24px; padding: 42px 0 26px;
    display: flex; flex-direction: column; gap: 20px;
  }
  .tag {
    display: inline-block; font-family: var(--font-tel); font-weight: 800;
    font-size: clamp(12px, 3.3vw, 18px); color: #fff; background: var(--navy); white-space: nowrap;
    padding: .6em 1.1em; border-radius: 0; box-shadow: 4px 4px 0 rgba(20, 55, 120, .22);
    transform: rotate(-2.5deg); margin-top: 0;
  }
  h1 { margin: 40px 0 0; }
  .catch { width: 72%; max-width: 560px; height: auto; display: block; margin-left: -8px; }
  .sub {
    font-family: var(--font-round); font-weight: 700; font-size: clamp(12px, 3vw, 16px);
    color: #3E4A5E; margin: 20px 0 0; line-height: 1.8;
  }
  .sub span { white-space: nowrap; }

  .price-card {
    background: rgba(255, 255, 255, .82); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    border: 1.5px solid rgba(255, 255, 255, .9); border-radius: 16px; padding: 10px 8px;
    box-shadow: 0 4px 18px rgba(20, 42, 84, .12);
    display: flex; align-items: stretch; justify-content: space-evenly; box-sizing: border-box;
    max-width: none; width: 100%; align-self: flex-start; margin: auto 0 0;
  }
  .cell { flex: none; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; text-align: center; }
  .label { font-size: 13.5px; font-weight: 800; color: var(--ink); }
  .value { line-height: 1.15; white-space: nowrap; }
  .num { font-family: var(--font-round); font-weight: 900; font-size: clamp(25px, 7.6vw, 34px); color: var(--orange); }
  .unit { font-size: clamp(12px, 3.4vw, 14px); font-weight: 800; color: var(--ink); margin-left: 3px; }
  .unit-l { margin: 0 6px 0 0; }
  .tilde { margin-left: 4px; }
  .v-line { width: 1.5px; background: rgba(20, 55, 120, .18); margin: 2px 0; }

  .cta-row { display: none; flex-direction: row; gap: 14px; max-width: 620px; margin-top: 4px; }
  .cta-consult, .cta-doc {
    flex: 1; display: flex; align-items: center; justify-content: center; gap: 9px;
    font-size: 16px; font-weight: 700; padding: 16px 12px; border-radius: 999px;
    text-decoration: none; white-space: nowrap; color: #fff;
  }
  .cta-consult { background: var(--navy); box-shadow: 0 5px 0 var(--navy-shadow); }
  .cta-doc { background: var(--orange); box-shadow: 0 5px 0 var(--orange-shadow); }
  .circle {
    width: 20px; height: 20px; border-radius: 50%; background: #fff;
    display: flex; align-items: center; justify-content: center; flex: none;
  }

  /* タブレット 768–1024px */
  @media (min-width: 768px) {
    .wrap { align-items: center; min-height: 520px; }
    .photo-narrow { display: none; }
    .photo-wide { display: block; }
    .fade {
      background:
        linear-gradient(to right, rgba(255,255,255,1) 4%, rgba(255,255,255,.88) 24%, rgba(255,255,255,0) 52%),
        linear-gradient(to top, #fff 0%, rgba(255,255,255,0) 16%);
    }
    .text { width: min(500px, 46%); max-width: 540px; margin-left: clamp(24px, 4.5vw, 80px); padding: 32px 0 40px; gap: 30px; }
    .tag { font-size: clamp(14px, 1.9vw, 22px); margin-top: 32px; }
    h1 { margin-top: 14px; }
    .catch { width: 110%; max-width: 560px; margin-left: 0; }
    .sub { font-size: clamp(12px, 1.7vw, 18px); color: var(--muted); margin-top: 16px; }
    .price-card { padding: 16px 8px; max-width: 480px; align-self: auto; margin: 0 auto; }
    .num { font-size: 34px; }
    .unit { font-size: 14px; }
  }

  /* PC >1024px */
  @media (min-width: 1025px) {
    .wrap { min-height: min(76vh, 700px); }
    .photo-wide { transform: translateX(11%); }
    .text { width: min(700px, 50%); max-width: 700px; }
    .tag { font-size: clamp(17px, 1.85vw, 36px); }
    .catch { max-width: 700px; }
    .sub { font-size: clamp(16px, 1.75vw, 26px); }
    .price-card { max-width: 620px; margin: 0; }
    .num { font-size: 44px; }
    .unit { font-size: 17px; }
    .cta-row { display: flex; }
  }
</style>
