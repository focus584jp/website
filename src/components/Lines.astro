---
// テキスト行プレースホルダ（ワイヤー用）。n本のグレー線を描く。最後の行は短く。
// head=true で上に小見出し風のバーを付ける。
const { n = 4, head = false } = Astro.props;
const arr = Array.from({ length: n });
---
<div>
  {head && <div class="wf-subhead"></div>}
  <div class="wf-lines">
    {arr.map((_, i) => <span style={`width:${i === n - 1 ? '70%' : '100%'}`}></span>)}
  </div>
</div>
