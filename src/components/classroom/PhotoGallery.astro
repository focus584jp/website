---
// ж•ҷе®ӨйўЁжҷҜгӮ®гғЈгғ©гғӘгғј: гӮөгғ гғҚгҒ®гӮ°гғӘгғғгғүпјӢгӮҝгғғгғ—гҒ§жӢЎеӨ§пјҲгғ©гӮӨгғҲгғңгғғгӮҜгӮ№пјүгҖӮ
// жӢЎеӨ§дёӯгҒҜ з”»еғҸгӮҝгғғгғ—/е·ҰеҸізҹўеҚ°/гӮ№гғҜгӮӨгғ— гҒ§еүҚеҫҢз§»еӢ•пјҲз«ҜгҒҜгғ«гғјгғ—пјүгҖҒиғҢжҷҜгӮҝгғғгғ—/вң•/Esc гҒ§й–үгҒҳгӮӢгҖӮ
// еҶҷзңҹгҒҢз„ЎгҒ„ж•ҷе®ӨгҒҜгғҖгғҹгғјгӮҝгӮӨгғ«гӮ’иЎЁзӨәгҒҷгӮӢпјҲsrc/assets/classrooms/<slug>/ гҒёгҒ®е®ҹеҶҷзңҹжҠ•е…ҘгҒ§иҮӘеӢ•еҲҮгӮҠжӣҝгҒҲпјүгҖӮ
// гғҖгғҹгғјжҷӮгӮӮгӮҝгӮӨгғ«гҒҜгӮҝгғғгғ—еҸҜиғҪгҒ§гҖҒгӮөгғігғ—гғ«з”»еғҸпјҲSVGпјүгҒ§гғ©гӮӨгғҲгғңгғғгӮҜгӮ№гҒ®жҢҷеӢ•гӮ’зўәиӘҚгҒ§гҒҚгӮӢгҖӮ
import type { ImageMetadata } from 'astro';
import { Image, getImage } from 'astro:assets';

interface Props { photos: ImageMetadata[]; roomName: string }
const { photos, roomName } = Astro.props;

// жӢЎеӨ§иЎЁзӨәз”ЁгҒ®еӨ§гҒҚгӮҒжңҖйҒ©еҢ–з”»еғҸпјҲгӮөгғ гғҚгҒЁгҒҜеҲҘгҒ«е№…1200гҒ§з”ҹжҲҗпјү
const fullImages = await Promise.all(photos.map((p) => getImage({ src: p, width: 1200 })));

// гғҖгғҹгғјжҷӮгҒ®жӢЎеӨ§з”ЁгӮөгғігғ—гғ«з”»еғҸпјҲSVGгӮ’data URIгҒ§еҹӢгӮҒиҫјгҒҝгҖӮе®ҹеҶҷзңҹжҠ•е…ҘгҒ§дҪҝгӮҸгӮҢгҒӘгҒҸгҒӘгӮӢпјү
const isPlaceholder = photos.length === 0;
const PH_COUNT = 3;
const phFull = (i: number) =>
  'data:image/svg+xml;utf8,' +
  encodeURIComponent(
    `<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="900">` +
      `<rect width="1200" height="900" fill="#EEF1F6"/>` +
      `<rect x="24" y="24" width="1152" height="852" rx="20" fill="none" stroke="#C9D2DE" stroke-width="4" stroke-dasharray="14 12"/>` +
      `<svg x="540" y="330" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="#8A96A8" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>` +
      `<text x="600" y="540" text-anchor="middle" font-family="Hiragino Kaku Gothic ProN, sans-serif" font-size="40" font-weight="700" fill="#8A96A8">еҶҷзңҹжә–еӮҷдёӯпјҲгӮөгғігғ—гғ« ${i + 1}пјү</text>` +
    `</svg>`,
  );
const count = isPlaceholder ? PH_COUNT : photos.length;
---
  <div class="gallery" data-lbx-root data-name={roomName} data-ph={isPlaceholder ? '1' : null}>
    {isPlaceholder
      ? [...Array(PH_COUNT).keys()].map((i) => (
          <button type="button" class="th th-ph" data-full={phFull(i)} aria-label={`еҶҷзңҹжә–еӮҷдёӯгҒ®гӮөгғігғ—гғ«${i + 1}гӮ’жӢЎеӨ§иЎЁзӨә`}>
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="9" cy="9" r="2"></circle><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path></svg>
            <span>еҶҷзңҹжә–еӮҷдёӯ</span>
          </button>
        ))
      : photos.map((p, i) => (
          <button type="button" class="th" data-full={fullImages[i].src} aria-label={`${roomName}гҒ®ж§ҳеӯҗ${i + 1}гӮ’жӢЎеӨ§иЎЁзӨә`}>
            <Image src={p} alt={`${roomName}гҒ®ж§ҳеӯҗ${i + 1}`} widths={[400, 800]} sizes="(min-width: 768px) 33vw, 50vw" class="photo" />
          </button>
        ))}

    <div class="lbx" role="dialog" aria-modal="true" aria-label={`${roomName}гҒ®еҶҷзңҹгҒ®жӢЎеӨ§иЎЁзӨә`} data-lbx>
      <div class="ov" data-close></div>
      <figure class="fig">
        <img class="big" data-big alt="" decoding="async" />
        <figcaption class="cp" data-cap></figcaption>
      </figure>
      <button type="button" class="ctl x" data-close aria-label="й–үгҒҳгӮӢ">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
      </button>
      {count > 1 && (
        <>
          <button type="button" class="ctl lnav prev" data-prev aria-label="еүҚгҒ®еҶҷзңҹгҒё">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
          </button>
          <button type="button" class="ctl lnav next" data-next aria-label="ж¬ЎгҒ®еҶҷзңҹгҒё">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
          </button>
        </>
      )}
    </div>
  </div>

<style>
  .gallery { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  @media (min-width: 768px) { .gallery { grid-template-columns: repeat(3, 1fr); } }

  .th { padding: 0; border: 0; background: none; display: block; border-radius: 14px; cursor: zoom-in; }
  .th:focus-visible { outline: 3px solid var(--orange); outline-offset: 2px; }
  .photo { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; border-radius: 14px; display: block; }

  /* гғҖгғҹгғјгӮҝгӮӨгғ«пјҲгӮҝгғғгғ—гҒ§гӮөгғігғ—гғ«з”»еғҸгҒ®гғ©гӮӨгғҲгғңгғғгӮҜгӮ№гҒҢй–ӢгҒҸпјү */
  .th-ph {
    aspect-ratio: 4 / 3; background: var(--panel);
    border: 1px dashed var(--line); color: var(--gray-1);
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px;
  }
  .th-ph span { font-family: var(--font-body); font-size: 12px; font-weight: 600; }

  /* гғ©гӮӨгғҲгғңгғғгӮҜгӮ№пјҲеӣәе®ҡCTAгҒ® z-index:60 гӮҲгӮҠеүҚйқўгҒ«пјү */
  .lbx {
    position: fixed; inset: 0; z-index: 100; padding: 20px;
    display: none; align-items: center; justify-content: center;
  }
  .lbx.is-open { display: flex; }
  .ov { position: absolute; inset: 0; background: rgba(16, 24, 34, .8); animation: lbx-fade .28s ease; }
  .fig {
    position: relative; margin: 0; max-width: 900px;
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    animation: lbx-zoom .28s ease;
  }
  .big {
    max-width: 100%; max-height: 76vh; max-height: 76dvh; border-radius: 14px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, .45);
    cursor: pointer; touch-action: none; user-select: none; -webkit-user-select: none;
  }
  .cp { color: #fff; font-size: 12.5px; font-weight: 700; letter-spacing: .04em; }

  .ctl {
    position: absolute; z-index: 1; width: 40px; height: 40px; padding: 0;
    border: none; border-radius: 50%; cursor: pointer;
    background: rgba(255, 255, 255, .94); color: var(--navy);
    display: grid; place-items: center; box-shadow: 0 2px 10px rgba(0, 0, 0, .35);
  }
  .x { top: max(14px, env(safe-area-inset-top)); right: 14px; }
  .lnav { top: 50%; transform: translateY(-50%); }
  .prev { left: 10px; }
  .next { right: 10px; }

  @keyframes lbx-fade { from { opacity: 0; } }
  @keyframes lbx-zoom { from { opacity: 0; transform: scale(.88); } }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-lbx-root]').forEach((root) => {
    const thumbs = [...root.querySelectorAll<HTMLButtonElement>('.th')];
    const box = root.querySelector<HTMLElement>('[data-lbx]');
    const big = root.querySelector<HTMLImageElement>('[data-big]');
    const cap = root.querySelector<HTMLElement>('[data-cap]');
    if (!box || !big || !cap || thumbs.length === 0) return;

    const fulls = thumbs.map((t) => t.dataset.full ?? '');
    const name = root.dataset.name ?? '';
    const isPh = root.dataset.ph === '1'; // гғҖгғҹгғјпјҲгӮөгғігғ—гғ«з”»еғҸпјүгғўгғјгғү
    const n = fulls.length;
    let idx = 0;
    let opener: HTMLElement | null = null;

    function render() {
      big!.src = fulls[idx];
      cap!.textContent = isPh ? `еҶҷзңҹжә–еӮҷдёӯпјҲгӮөгғігғ—гғ« ${idx + 1} / ${n}пјү` : `${name}гҒ®ж§ҳеӯҗ ${idx + 1} / ${n}`;
      if (n > 1) new Image().src = fulls[(idx + 1) % n]; // ж¬ЎгҒ®1жһҡгӮ’е…ҲиӘӯгҒҝ
    }
    const next = () => { idx = (idx + 1) % n; render(); };
    const prev = () => { idx = (idx - 1 + n) % n; render(); };

    function onKey(e: KeyboardEvent) {
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowRight') next();
      else if (e.key === 'ArrowLeft') prev();
    }
    function open(i: number, from: HTMLElement | null) {
      idx = i;
      opener = from;
      render();
      box!.classList.add('is-open');
      document.body.style.overflow = 'hidden'; // иғҢйқўгӮ№гӮҜгғӯгғјгғ«гӮ’жӯўгӮҒгӮӢ
      document.addEventListener('keydown', onKey);
      box!.querySelector<HTMLElement>('.x')?.focus({ preventScroll: true });
    }
    function close() {
      box!.classList.remove('is-open');
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onKey);
      opener?.focus({ preventScroll: true });
    }

    thumbs.forEach((t, i) => t.addEventListener('click', () => open(i, t)));
    box.addEventListener('click', (e) => {
      const el = e.target as Element;
      if (el.closest('[data-close]')) close();
      else if (el.closest('[data-prev]')) prev();
      else if (el.closest('[data-next]')) next();
    });

    // жӢЎеӨ§з”»еғҸ: гӮҝгғғгғ—гҒ§ж¬ЎгҒёгҖҒгӮ№гғҜгӮӨгғ—гҒ§еүҚеҫҢпјҲгӮ№гғҜгӮӨгғ—зӣҙеҫҢгҒ®clickгҒҜз„ЎиҰ–пјү
    let startX = 0;
    let swiped = false;
    big.addEventListener('pointerdown', (e) => { startX = e.clientX; swiped = false; });
    big.addEventListener('pointerup', (e) => {
      const dx = e.clientX - startX;
      if (n > 1 && Math.abs(dx) > 50) {
        swiped = true;
        if (dx < 0) next(); else prev();
      }
    });
    big.addEventListener('click', () => { if (!swiped && n > 1) next(); });

    // DEVе°Ӯз”Ё: ?lbx=<index> гҒ§иҮӘеӢ•гӮӘгғјгғ—гғіпјҲе®ҹж©ҹзўәиӘҚз”ЁгҖӮжң¬з•Әгғ“гғ«гғүгҒ§гҒҜйҷӨеҺ»гҒ•гӮҢгӮӢпјү
    if (import.meta.env.DEV) {
      const q = new URLSearchParams(location.search).get('lbx');
      if (q !== null) open(Math.min(Number(q) || 0, n - 1), null);
    }
  });
</script>
