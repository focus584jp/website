---
// 時間割（教室詳細ページ）。例の生徒A〜Dをタップで切り替え、選んだ生徒の受講例（科目つき）だけを表示する。
// データは src/data/timetable.ts（全教室共通）。同じコマに複数の生徒が重なってよい（表示は選択中の生徒のみ）。
import { timetableDays, timetableTimes, timetablePersonas, timetableNotes } from '../../data/timetable';

// (時間帯×曜日) → その枠に入っている生徒たち（キーと科目）
const cellEntries = (time: string, day: string) =>
  timetablePersonas.flatMap((p) =>
    p.slots.filter((s) => s.time === time && s.day === day).map((s) => ({ key: p.key, subject: s.subject })),
  );
---
<div class="tt" data-tt>
  <p class="tt-lead">部活や習い事に合わせて、通う曜日・時間帯を選べます。</p>

  {/* 切替チップ（時間割の上に置き、スクロールせずに切り替えられるようにする） */}
  <p class="sw-cap">（例）タップして、生徒ごとの通い方を見る</p>
  <div class="sw">
    {timetablePersonas.map((p) => (
      <button type="button" class:list={['sw-btn', `p-${p.key.toLowerCase()}`]} data-persona={p.key} aria-pressed="false">{p.key}</button>
    ))}
  </div>
  {timetablePersonas.map((p) => (
    <p class:list={['sw-desc', `p-${p.key.toLowerCase()}`]} data-desc={p.key}><b>{p.key}</b>{p.label}</p>
  ))}

  <div class="tt-grid">
    <table class="tbl">
      <thead>
        <tr>
          <th class="corner"></th>
          {timetableDays.map((d) => <th class="day">{d}</th>)}
        </tr>
      </thead>
      <tbody>
        {timetableTimes.map((r) => (
          <tr class:list={{ seasonal: r.seasonal }}>
            <th class="time">{r.time}</th>
            {timetableDays.map((d) => (
              <td>
                {cellEntries(r.time, d).map((e) => <span class="pk" data-p={e.key}>{e.subject}</span>)}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>

    {/* PC用の切替カード（説明4枚を常時表示。SPではチップ式=上のswを使う） */}
    <div class="legend">
      {timetablePersonas.map((p) => (
        <button type="button" class:list={['lg-item', `p-${p.key.toLowerCase()}`]} data-persona={p.key} aria-pressed="false">
          <span class="lg-key">{p.key}</span>
          <span class="lg-text">{p.label}</span>
        </button>
      ))}
    </div>
  </div>

  <ul class="notes">
    {timetableNotes.map((nt) => <li>{nt}</li>)}
  </ul>
</div>

<script>
  // 凡例のA〜Dをタップ → その生徒の受講例（科目）だけを時間割に表示する（初期表示はA）
  document.querySelectorAll<HTMLElement>('[data-tt]').forEach((root) => {
    const btns = [...root.querySelectorAll<HTMLButtonElement>('[data-persona]')];
    const descs = [...root.querySelectorAll<HTMLElement>('[data-desc]')];
    const cells = [...root.querySelectorAll<HTMLTableCellElement>('tbody td')];
    const PCLASSES = ['p-a', 'p-b', 'p-c', 'p-d'];
    function select(key: string) {
      btns.forEach((b) => {
        const on = b.dataset.persona === key;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-pressed', String(on));
      });
      descs.forEach((d) => d.classList.toggle('on', d.dataset.desc === key));
      cells.forEach((td) => {
        const span = td.querySelector<HTMLElement>(`[data-p="${key}"]`);
        td.querySelectorAll<HTMLElement>('.pk').forEach((s) => s.classList.toggle('on', s === span));
        PCLASSES.forEach((c) => td.classList.remove(c));
        if (span) td.classList.add(`p-${key.toLowerCase()}`);
      });
    }
    btns.forEach((b) => b.addEventListener('click', () => select(b.dataset.persona ?? '')));
    select('A');

    // DEV専用: ?tt=B〜D で切替状態を直接表示（動作確認用。本番ビルドでは除去される）
    if (import.meta.env.DEV) {
      const q = new URLSearchParams(location.search).get('tt');
      if (q) select(q.toUpperCase());
    }
  });
</script>

<style>
  .tt-lead { font-size: 14.5px; line-height: 1.9; color: var(--ink); margin: 0 0 18px; }

  .tbl { width: 100%; border-collapse: separate; border-spacing: 4px; table-layout: fixed; }
  .tbl th.corner { width: 66px; background: none; }
  .tbl .day {
    background: var(--navy); color: #fff; font-family: var(--font-round);
    font-size: 13.5px; font-weight: 900; padding: 8px 0; border-radius: 7px;
  }
  .tbl .time {
    background: var(--panel); color: var(--navy); font-size: 13px; font-weight: 800;
    font-family: var(--font-tel); padding: 0 4px; border-radius: 7px; white-space: nowrap;
  }
  .tbl td {
    background: var(--alt-bg); border-radius: 7px; text-align: center; height: 38px;
    transition: background .2s;
  }
  /* 講習期間のみの行は低くして全体の縦を圧縮 */
  .tbl tr.seasonal td { background: #E4E9F0; height: 24px; }
  .tbl tr.seasonal .time { color: var(--gray-1); font-size: 11px; }

  /* セル内の科目（選択中の生徒のものだけ .on で表示。JSが切り替える） */
  .pk { display: none; font-family: var(--font-round); font-size: 13px; font-weight: 900; letter-spacing: .04em; }
  .pk.on { display: inline; }

  /* 例の生徒の色（面=デザイントークンの淡色4種、文字=対応する濃色。凡例のバッジも同色） */
  .tbl td.p-a { background: #FBDECB; color: var(--orange-shadow); } /* 淡橙 */
  .tbl td.p-b { background: var(--blue-pale); color: var(--navy); } /* 淡青 */
  .tbl td.p-c { background: #FCF3D7; color: #9A6A12; } /* 淡黄（文字=warning-text） */
  .tbl td.p-d { background: var(--success-bg); color: var(--success-text); } /* 淡緑 */

  /* 切替チップ（時間割の上。1画面内で切替→時間割の変化が見える） */
  .sw-cap { font-size: 12.5px; font-weight: 700; color: var(--muted); text-align: center; margin: 0 0 8px; }
  .sw { display: flex; justify-content: center; gap: 12px; margin: 0 0 10px; }
  .sw-btn {
    width: 42px; height: 42px; border-radius: 50%; border: none; padding: 0;
    font-family: var(--font-round); font-size: 16.5px; font-weight: 900;
    cursor: pointer; opacity: .42; transition: opacity .2s, transform .2s, box-shadow .2s;
  }
  .sw-btn.is-active { opacity: 1; transform: scale(1.12); box-shadow: 0 3px 10px rgba(20, 42, 84, .25); }
  .sw-btn.p-a { background: #FBDECB; color: var(--orange-shadow); }
  .sw-btn.p-b { background: var(--blue-pale); color: var(--navy); }
  .sw-btn.p-c { background: #FCF3D7; color: #9A6A12; }
  .sw-btn.p-d { background: var(--success-bg); color: var(--success-text); }

  /* 選択中の生徒の説明（1行。JSが .on を付け外し） */
  .sw-desc {
    display: none; text-align: center; border-radius: 10px; padding: 8px 12px; margin: 0 0 14px;
    font-size: 13px; font-weight: 700; color: var(--ink); line-height: 1.6;
  }
  .sw-desc.on { display: block; }
  .sw-desc b { font-family: var(--font-round); font-weight: 900; margin-right: 8px; }
  .sw-desc.p-a { background: #FBDECB; } .sw-desc.p-a b { color: var(--orange-shadow); }
  .sw-desc.p-b { background: var(--blue-pale); } .sw-desc.p-b b { color: var(--navy); }
  .sw-desc.p-c { background: #FCF3D7; } .sw-desc.p-c b { color: #9A6A12; }
  .sw-desc.p-d { background: var(--success-bg); } .sw-desc.p-d b { color: var(--success-text); }

  .notes { margin: 18px 0 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 4px; }
  .notes li { font-size: 12.5px; color: var(--muted); line-height: 1.8; padding-left: 1.4em; text-indent: -1.4em; }
  .notes li::before { content: '※ '; }

  /* 極小スマホ（〜399px）: 科目2文字が収まるように詰める */
  @media (max-width: 399px) {
    .tbl { border-spacing: 3px; }
    .tbl th.corner { width: 56px; }
    .tbl .time { font-size: 11.5px; }
    .tbl .day { font-size: 12.5px; }
    .pk { font-size: 11.5px; letter-spacing: 0; }
  }

  .tt { max-width: 620px; margin-inline: auto; }

  /* PC用の切替カード（SPでは非表示） */
  .legend { display: none; }
  .lg-item {
    display: flex; align-items: center; gap: 10px; width: 100%; text-align: left;
    background: #fff; border: 1.5px solid var(--line); border-radius: 10px; padding: 11px 13px;
    font-family: var(--font-body); font-size: 13.5px; font-weight: 700; color: var(--ink); line-height: 1.5;
    cursor: pointer; opacity: .6; transition: background .2s, border-color .2s, opacity .2s;
  }
  .lg-item:hover { opacity: 1; }
  .lg-item.is-active { border-color: transparent; box-shadow: var(--shadow-card); opacity: 1; }
  .lg-key {
    width: 25px; height: 25px; border-radius: 50%;
    display: grid; place-items: center; flex: none;
    font-family: var(--font-round); font-size: 13px; font-weight: 900;
    transition: background .2s;
  }
  .lg-item.p-a .lg-key { background: #FBDECB; color: var(--orange-shadow); }
  .lg-item.p-b .lg-key { background: var(--blue-pale); color: var(--navy); }
  .lg-item.p-c .lg-key { background: #FCF3D7; color: #9A6A12; }
  .lg-item.p-d .lg-key { background: var(--success-bg); color: var(--success-text); }
  .lg-item.is-active.p-a { background: #FBDECB; }
  .lg-item.is-active.p-b { background: var(--blue-pale); }
  .lg-item.is-active.p-c { background: #FCF3D7; }
  .lg-item.is-active.p-d { background: var(--success-bg); }
  .lg-item.is-active .lg-key { background: rgba(255, 255, 255, .88); }

  /* PC: 左に時間割・右に切替カードの2カラム。時間列も広めに */
  @media (min-width: 1024px) {
    .tt { max-width: none; }
    .sw-cap, .sw, .sw-desc, .sw-desc.on { display: none; }
    .tt-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 36px; align-items: center; }
    .legend { display: flex; flex-direction: column; gap: 10px; }
    .tbl th.corner { width: 88px; }
    .tbl .time { font-size: 14.5px; padding: 0 8px; }
  }
</style>
