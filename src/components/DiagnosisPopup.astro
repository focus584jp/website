---
// 画面の隅からにゅっと出る相性診断への誘導。タップで /diagnosis へ。
// 一度閉じたらそのセッションでは再表示しない（sessionStorage）。
import { u } from '../lib/path';
---
<div class="wf-diagpop" id="wf-diagpop" data-state="hidden">
  <a class="body" href={u('/diagnosis')}>
    <span class="lead">うちの子、FOCUSに合う？</span>
    <span class="cta">30秒で相性診断 →</span>
  </a>
  <button class="close" id="wf-diagpop-close" aria-label="閉じる" type="button">×</button>
</div>

<script>
  const KEY = 'wf-diagpop-dismissed';
  const el = document.getElementById('wf-diagpop');
  const close = document.getElementById('wf-diagpop-close');
  if (el && sessionStorage.getItem(KEY) !== '1') {
    // 少しスクロールしてから出す（広告と誤認されにくい）
    const show = () => el.setAttribute('data-state', 'shown');
    if (window.scrollY > 400) show();
    else window.addEventListener('scroll', function onScroll() {
      if (window.scrollY > 400) { show(); window.removeEventListener('scroll', onScroll); }
    }, { passive: true });
  }
  close?.addEventListener('click', () => {
    el?.setAttribute('data-state', 'hidden');
    sessionStorage.setItem(KEY, '1');
  });
</script>
