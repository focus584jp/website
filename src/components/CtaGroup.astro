---
// CV導線3点セット（順序固定：資料請求＞無料相談＞電話）。CTAのみブランド色。
// size="lg" で大きめ。LINE相談は保留（採用時にここへ差し込む）。
const { size } = Astro.props;
const lg = size === 'lg' ? ' lg' : '';
---
<div class="wf-cta-group">
  <a class={`wf-btn wf-btn-primary${lg}`} href="/document">資料請求</a>
  <a class={`wf-btn wf-btn-secondary${lg}`} href="/consult">無料相談</a>
</div>
