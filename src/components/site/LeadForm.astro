---
// フォーム2種共通の3ステップフォーム（入力→確認→完了。ページ内切替）。
// 文言・バリアント定義は src/data/forms.ts。ベースの見た目は site.css の .form-card / .f-field / .f-submit。
// 送信バックエンド（GAS）は未接続: 本番は送信ボタンdisabled＋「準備中」表記、DEVのみ完了画面まで進める。
// 設計: docs/superpowers/specs/2026-07-10-form-confirm-step-design.md
import { classrooms } from '../../data/classrooms';
import { grades, leadForms, LEAD_API_URL, type LeadFormVariant } from '../../data/forms';

interface Props { variant: LeadFormVariant }
const { variant } = Astro.props;
const cfg = leadForms[variant];
const isDev = import.meta.env.DEV;
// APIが未設定の間は本番の送信ボタンをdisabled＋「準備中」表記のまま公開できる
const formEnabled = isDev || LEAD_API_URL !== '';

// 「次へ進む」はアウトライン（白地＋紺枠）で統一し、塗り＋立体3D（request=橙/consult=紺）は確認画面の最終送信ボタンだけに使う
const nextClass = ['f-submit', 'flat'];
const sendClass = cfg.theme === 'navy' ? ['f-submit', 'btn3d', 'btn3d-n', 'navy'] : ['f-submit', 'btn3d', 'btn3d-o', 'btn-shine'];
const STEPS = ['入力', '確認', '完了'];
---
<div class="lead-form" data-lead-form data-phone-pattern={cfg.phonePattern} data-variant={variant} data-api={LEAD_API_URL}>
  <ol class="steps" aria-label="お申し込みの手順">
    {STEPS.map((label, i) => (
      <li class:list={['step', { 'is-current': i === 0 }]} data-step>
        <span class="s-num">
          <span class="s-n">{i + 1}</span>
          <svg class="s-ck" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
        </span>{label}
      </li>
    ))}
  </ol>

  {/* --- 1. 入力 --- */}
  <form class="form-card" data-view="input" novalidate tabindex="-1">
    <label class="f-field" data-field="name">
      <span>保護者さまのお名前<em>必須</em></span>
      <input type="text" name="name" placeholder="例：佐藤 由美" autocomplete="name" required />
      <p class="f-err" hidden>お名前を入力してください</p>
    </label>
    <label class="f-field" data-field="grade">
      <span>お子さまの学年<em>必須</em></span>
      <select name="grade" required>
        <option value="">選択してください</option>
        {grades.map((g) => <option value={g}>{g}</option>)}
      </select>
      <p class="f-err" hidden>学年を選択してください</p>
    </label>
    <label class="f-field" data-field="phone">
      <span>{cfg.phoneLabel}<em>必須</em></span>
      <input type="tel" name="phone" placeholder={cfg.phonePlaceholder} inputmode="numeric" autocomplete="tel" required />
      <p class="f-err" hidden>{cfg.phoneError}</p>
    </label>
    <label class="f-field" data-field="classroom">
      <span>{cfg.classroomLabel}<em>必須</em></span>
      <select name="classroom" required>
        <option value="">選択してください</option>
        {/* 表示・送信値とも「西千葉」形式（末尾の「教室」なし。API側は教室マスタ照合時に有無を吸収） */}
        {classrooms.map((c) => <option value={c.name.replace(/教室$/, '')}>{c.name.replace(/教室$/, '')}</option>)}
      </select>
      <p class="f-err" hidden>教室を選択してください</p>
    </label>
    {/* honeypot: botよけの隠しフィールド（人間には見えない。入力されていたらサーバ側でspam扱い） */}
    <div class="hp-wrap" aria-hidden="true">
      <input type="text" name="hp" tabindex="-1" autocomplete="off" />
    </div>
    <button type="submit" class:list={nextClass}>
      入力内容を確認する
      <span class="ar-c" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h15"></path><path d="m13 6 6 6-6 6"></path></svg></span>
    </button>
    {cfg.note && <p class="f-note" set:html={cfg.note} />}
    {!formEnabled && <p class="f-note note-draft">※送信機能は準備中です（フォームはまだ動作しません）</p>}
  </form>

  {/* --- 2. 確認 --- */}
  <div class="form-card" data-view="confirm" hidden tabindex="-1">
    <p class="confirm-lead">この内容でよろしいですか？</p>
    <dl class="confirm-list">
      <div class="row"><dt>保護者さまのお名前</dt><dd data-out="name"></dd></div>
      <div class="row"><dt>お子さまの学年</dt><dd data-out="grade"></dd></div>
      <div class="row"><dt>{cfg.phoneLabel}</dt><dd data-out="phone"></dd></div>
      <div class="row"><dt>{cfg.classroomLabel}</dt><dd data-out="classroom"></dd></div>
    </dl>
    <button type="button" class:list={sendClass} data-send disabled={!formEnabled}>
      <span class="send-layer send-idle">
        {variant === 'request' && <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v11"></path><path d="m7 10 5 5 5-5"></path><path d="M4 21h16"></path></svg>}
        {cfg.submitLabel}
      </span>
      <span class="send-layer send-busy" hidden>
        <span class="spinner" aria-hidden="true"></span>送信しています…
      </span>
      <span class="send-layer send-fly" hidden aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"></path><path d="m21.854 2.147-10.94 10.939"></path></svg>
      </span>
    </button>
    {!formEnabled && <p class="f-note note-draft">※送信機能は準備中です（フォームはまだ動作しません）</p>}
    <p class="f-note send-error" data-send-error hidden>送信できませんでした。お手数ですが、時間をおいてもう一度お試しください。</p>
    <button type="button" class="back-btn" data-back>← 入力画面に戻って修正する</button>
  </div>

  {/* --- 3. 完了 --- */}
  <div class="form-card done-view" data-view="done" hidden tabindex="-1">
    <svg class="done-ic" width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="m9 12 2 2 4-4"></path></svg>
    <p class="done-title">{cfg.doneTitle}</p>
    <p class="done-body">{cfg.doneBody}</p>
  </div>
</div>

<style>
  .lead-form { scroll-margin-top: 84px; }
  [data-view]:focus { outline: none; }
  /* .form-card の display:flex が hidden 属性（UAスタイル）に勝ってしまうため明示する */
  [data-view][hidden] { display: none; }

  /* ステップ表示 */
  .steps { list-style: none; display: flex; justify-content: center; align-items: center; gap: 10px; margin: 0 0 20px; padding: 0; }
  .step { display: flex; align-items: center; gap: 6px; font-size: 12.5px; font-weight: 700; color: var(--gray-1); }
  .step:not(:first-child)::before { content: ""; width: 18px; height: 1.5px; background: var(--line); margin-right: 10px; }
  .s-num {
    width: 22px; height: 22px; border-radius: 50%; background: #E3E9F0; color: var(--muted);
    display: grid; place-items: center; font-size: 12px; font-weight: 800;
  }
  .step.is-current { color: var(--navy); }
  .step.is-current .s-num { background: var(--navy); color: #fff; }
  /* 完了済みステップはグレー丸＋チェック（番号と差し替え。控えめに=緑は完了画面のみ） */
  .s-ck { display: none; }
  .step.is-done .s-num { background: var(--gray-1); }
  .step.is-done .s-n { display: none; }
  .step.is-done .s-ck { display: block; }

  /* 紺バリアント（.f-submit のデフォルトは橙） */
  .navy { background: var(--navy); box-shadow: 0 5px 0 var(--navy-shadow); }
  /* 進行ボタンはアウトライン（塗り＋立体3DはCV用ボタン専用） */
  .flat { background: #fff; color: var(--navy); border: 2px solid var(--navy); box-shadow: none; }
  .ar-c {
    width: 20px; height: 20px; border-radius: 50%; background: var(--navy); flex: none;
    display: flex; align-items: center; justify-content: center;
  }
  .flat:active { transform: translateY(1px); }

  /* バリデーションエラー */
  .f-err { font-size: 12.5px; font-weight: 700; color: #C0392B; margin: 0; }
  .f-field.is-error :is(input, select) { border-color: #C0392B; }

  .note-draft { color: #C0392B; font-weight: 700; }
  .send-error { color: #C0392B; font-weight: 700; }

  /* honeypot: 視覚・タブ順から隠す（display:noneだとbotが埋めないことがあるため画面外へ） */
  form[data-view='input'] { position: relative; }
  .hp-wrap { position: absolute; left: -9999px; top: 0; width: 1px; height: 1px; overflow: hidden; }

  /* 確認画面 */
  .confirm-lead { font-size: 16.5px; font-weight: 800; color: var(--ink); text-align: center; margin: 0; }
  .confirm-list { margin: 0; display: flex; flex-direction: column; }
  .confirm-list .row { display: flex; flex-direction: column; gap: 2px; padding: 12px 2px; border-bottom: 1px solid var(--line); }
  .confirm-list .row:first-child { padding-top: 0; }
  .confirm-list dt { font-size: 12.5px; font-weight: 700; color: var(--muted); }
  .confirm-list dd { margin: 0; font-size: 17px; font-weight: 700; color: var(--ink); overflow-wrap: anywhere; }
  .back-btn {
    background: none; border: none; cursor: pointer; padding: 6px;
    font: 700 14px var(--font-body); color: var(--navy); text-decoration: underline; text-underline-offset: 3px;
  }
  .back-btn:disabled { opacity: .45; cursor: default; }

  /* 送信ボタンの状態レイヤー（通常/送信中/紙飛行機） */
  .is-sending { background: var(--gray-1); box-shadow: 0 5px 0 #6E7A8C; cursor: default; }
  .send-layer { display: flex; align-items: center; justify-content: center; gap: 9px; }
  .send-layer[hidden] { display: none; }
  .spinner {
    width: 17px; height: 17px; border-radius: 50%; flex: none;
    border: 2.5px solid rgba(255, 255, 255, .35); border-top-color: #fff;
    animation: lf-spin .7s linear infinite;
  }
  @keyframes lf-spin { to { transform: rotate(360deg); } }
  .send-fly svg { animation: lf-fly .7s ease-in forwards; }
  @keyframes lf-fly {
    0% { transform: translate(0, 0) rotate(0deg); opacity: 1; }
    15% { transform: translate(-6px, 3px) rotate(8deg); opacity: 1; } /* ひと呼吸ためてから飛ぶ */
    100% { transform: translate(130px, -80px) rotate(-14deg); opacity: 0; }
  }

  /* 完了画面 */
  .done-view { text-align: center; align-items: center; gap: 12px; padding-top: clamp(30px, 5vw, 40px); padding-bottom: clamp(30px, 5vw, 40px); }
  .done-ic { color: var(--success-text); }
  .done-title { font-family: var(--font-round); font-weight: 900; font-size: 20px; color: var(--ink); margin: 0; }
  .done-body { font-size: 14.5px; line-height: 2; color: var(--ink); margin: 0; max-width: 400px; }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-lead-form]').forEach((root) => {
    const form = root.querySelector<HTMLFormElement>('form[data-view="input"]');
    const confirmView = root.querySelector<HTMLElement>('[data-view="confirm"]');
    const doneView = root.querySelector<HTMLElement>('[data-view="done"]');
    if (!form || !confirmView || !doneView) return;
    const views = { input: form, confirm: confirmView, done: doneView };
    const steps = [...root.querySelectorAll<HTMLElement>('[data-step]')];
    const phonePattern = new RegExp(root.dataset.phonePattern ?? '');

    const field = (name: string) => form.elements.namedItem(name) as HTMLInputElement | HTMLSelectElement;
    // 全角数字→半角に直してから数字だけ取り出す（判定・表示は正規化後の値で行う）
    const toHalf = (s: string) => s.replace(/[０-９]/g, (c) => String.fromCharCode(c.charCodeAt(0) - 0xfee0));
    const phoneDigits = () => toHalf(field('phone').value).replace(/\D/g, '');
    const fmtPhone = (d: string) =>
      d.length === 11 ? `${d.slice(0, 3)}-${d.slice(3, 7)}-${d.slice(7)}`
      : d.length === 10 ? `${d.slice(0, 2)}-${d.slice(2, 6)}-${d.slice(6)}`
      : d;

    // 携帯番号（070/080/090）は入力中に自動でハイフンを挿入する。
    // 固定電話（consultのみ許容）は市外局番で桁割りが異なり誤整形になるため数字のまま。
    const phoneInput = field('phone') as HTMLInputElement;
    phoneInput.addEventListener('input', () => {
      const d = toHalf(phoneInput.value).replace(/\D/g, '').slice(0, 11);
      phoneInput.value = /^0[789]0/.test(d)
        ? d.length <= 3 ? d
        : d.length <= 7 ? `${d.slice(0, 3)}-${d.slice(3)}`
        : `${d.slice(0, 3)}-${d.slice(3, 7)}-${d.slice(7)}`
        : d;
    });
    // ハイフン直後でバックスペースしたときは、手前の数字ごと消す（ハイフンが再挿入されて消せなくなるのを防ぐ）
    phoneInput.addEventListener('keydown', (e) => {
      const p = phoneInput.selectionStart ?? 0;
      if (e.key === 'Backspace' && p > 1 && phoneInput.selectionEnd === p && phoneInput.value[p - 1] === '-') {
        e.preventDefault();
        phoneInput.value = phoneInput.value.slice(0, p - 2) + phoneInput.value.slice(p);
        phoneInput.dispatchEvent(new Event('input')); // 再整形
      }
    });

    function setError(name: string, on: boolean) {
      const wrap = form!.querySelector<HTMLElement>(`[data-field="${name}"]`);
      wrap?.classList.toggle('is-error', on);
      const err = wrap?.querySelector<HTMLElement>('.f-err');
      if (err) err.hidden = !on;
    }

    function validate(): boolean {
      const checks: Array<[string, boolean]> = [
        ['name', field('name').value.trim().length > 0],
        ['grade', field('grade').value !== ''],
        ['phone', phonePattern.test(phoneDigits())],
        ['classroom', field('classroom').value !== ''],
      ];
      let firstBad: string | null = null;
      for (const [name, ok] of checks) {
        setError(name, !ok);
        if (!ok) firstBad ??= name;
      }
      if (firstBad) field(firstBad).focus();
      return !firstBad;
    }

    function fillConfirm() {
      const values: Record<string, string> = {
        name: field('name').value.trim(),
        grade: field('grade').value,
        phone: fmtPhone(phoneDigits()),
        classroom: field('classroom').value,
      };
      for (const [k, v] of Object.entries(values)) {
        const dd = confirmView!.querySelector<HTMLElement>(`[data-out="${k}"]`);
        if (dd) dd.textContent = v;
      }
    }

    const ORDER = ['input', 'confirm', 'done'] as const;
    function show(name: (typeof ORDER)[number]) {
      const cur = ORDER.indexOf(name);
      ORDER.forEach((k, i) => {
        views[k].hidden = k !== name;
        steps[i]?.classList.toggle('is-current', i === cur);
        steps[i]?.classList.toggle('is-done', i < cur);
      });
      root.scrollIntoView({ behavior: 'smooth', block: 'start' });
      views[name].focus({ preventScroll: true });
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (!validate()) return;
      fillConfirm();
      show('confirm');
    });
    const sendBtn = confirmView.querySelector<HTMLButtonElement>('[data-send]');
    const backBtn = confirmView.querySelector<HTMLButtonElement>('[data-back]');
    const sendState = (state: 'idle' | 'busy' | 'fly') => {
      sendBtn?.querySelectorAll<HTMLElement>('.send-layer').forEach((el) => {
        el.hidden = !el.classList.contains(`send-${state}`);
      });
      sendBtn?.classList.toggle('is-sending', state !== 'idle'); // 送信中〜紙飛行機の間はグレー
    };
    const wait = (ms: number) => new Promise((r) => setTimeout(r, ms));

    backBtn?.addEventListener('click', () => show('input'));

    const api = root.dataset.api ?? '';
    const variant = root.dataset.variant ?? '';
    const errEl = confirmView.querySelector<HTMLElement>('[data-send-error]');

    sendBtn?.addEventListener('click', async () => {
      // 二重送信防止: 押した瞬間に無効化してスピナー表示（戻るも止める）
      sendBtn.disabled = true;
      if (backBtn) backBtn.disabled = true;
      if (errEl) errEl.hidden = true;
      sendState('busy');

      let ok = true;
      if (api) {
        // lead-api（GAS Web App）へ送信。text/plain は CORS プリフライト回避の定石
        try {
          const payload = {
            form: variant,
            name: field('name').value.trim(),
            grade: field('grade').value,
            phone: phoneDigits(),
            classroom: field('classroom').value,
            env: location.hostname === 'focus584jp.github.io' ? 'production' : 'staging',
            hp: (form.elements.namedItem('hp') as HTMLInputElement | null)?.value ?? '',
          };
          const res = await fetch(api, {
            method: 'POST',
            headers: { 'Content-Type': 'text/plain;charset=utf-8' },
            body: JSON.stringify(payload),
          });
          ok = res.ok && (await res.json()).ok === true;
        } catch {
          ok = false;
        }
      } else {
        await wait(900); // API未設定（DEVデモ）: 成功の体で完了画面まで確認できる
      }

      if (!ok) {
        // 失敗: ボタンを戻してエラー表示（そのまま再試行できる）
        sendState('idle');
        sendBtn.disabled = false;
        if (backBtn) backBtn.disabled = false;
        if (errEl) errEl.hidden = false;
        return;
      }

      // 送信完了 → 紙飛行機が飛んで完了画面へ
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
        sendState('fly');
        await wait(700);
      }
      show('done');
      sendState('idle'); // 「修正する」で戻って再送信するケースに備えて復帰
      sendBtn.disabled = false;
      if (backBtn) backBtn.disabled = false;
    });

    // DEV専用: ?step=confirm|busy|done でサンプル値を流し込んで直接表示（動作確認用。本番ビルドでは除去される）
    if (import.meta.env.DEV) {
      const step = new URLSearchParams(location.search).get('step');
      if (step === 'confirm' || step === 'busy' || step === 'done') {
        field('name').value = '佐藤 由美';
        field('grade').value = '中2';
        field('phone').value = '０９０-1234-5678';
        (field('classroom') as HTMLSelectElement).selectedIndex = 1;
        fillConfirm();
        if (step === 'busy') {
          show('confirm');
          if (sendBtn) sendBtn.disabled = true;
          sendState('busy');
        } else {
          show(step);
        }
      }
    }
  });
</script>
