---
// CTAバンド — ＼ お気軽にお問い合わせください ／ ＋ 資料DL / 無料相談 / 電話番号
import { phone, ctaLabels } from '../../data/home';
import { u } from '../../lib/path';
import Icon from './Icon.astro';
import ArrowCircle from './ArrowCircle.astro';
---
<section class="cta-band">
  <div class="container">
    <h2 class="lead-in"><span class="slash">＼</span>お気軽にお問い合わせください<span class="slash">／</span></h2>
    <div class="buttons">
      <a href={u('/request')} class="btn-shine btn3d btn3d-o doc"><Icon name="download" size={16} stroke="#fff" strokeWidth={2.6} />{ctaLabels.doc}</a>
      <a href={u('/consult')} class="btn3d btn3d-n consult">{ctaLabels.consult}<ArrowCircle /></a>
    </div>
    <div class="tel-block">
      <p class="tel-label">お電話でのお問い合わせはこちら</p>
      <a href={phone.tel} class="tel-num">
        <Icon name="phone" size={22} stroke="#E67832" strokeWidth={2.2} />
        {phone.display}
      </a>
      <p class="tel-hours">{phone.hours}</p>
    </div>
  </div>
</section>

<style>
  .cta-band { background: rgba(221, 231, 247, .55); } /* --blue-paleの55%。alt-bgより一段ブルー */
  .container { max-width: 560px; margin: 0 auto; padding: clamp(48px, 7vw, 80px) 24px; text-align: center; }
  .lead-in {
    font-family: var(--font-round); font-weight: 900; font-size: clamp(19px, 2.6vw, 24px);
    color: var(--navy); margin: 0 0 22px;
  }
  .slash { color: var(--orange); margin: 0 .35em; font-weight: 900; }

  .buttons { display: flex; flex-direction: column; gap: 12px; max-width: 380px; margin: 0 auto; }
  .buttons a {
    display: flex; align-items: center; justify-content: center; gap: 9px;
    font-size: 16px; font-weight: 700; padding: 16px; border-radius: 999px; text-decoration: none; color: #fff;
  }
  .doc { background: var(--orange); box-shadow: 0 5px 0 var(--orange-shadow); }
  .consult { background: var(--navy); box-shadow: 0 5px 0 var(--navy-shadow); }

  .tel-block { margin-top: 26px; }
  .tel-label { font-size: 14px; font-weight: 700; color: var(--ink); margin: 0; }
  .tel-num {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px; margin-top: 6px;
    font-family: var(--font-tel); font-size: clamp(28px, 6vw, 32px); font-weight: 800;
    letter-spacing: .02em; color: var(--navy); text-decoration: none;
  }
  .tel-hours { font-size: 12.5px; color: var(--muted); margin: 4px 0 0; }
</style>
