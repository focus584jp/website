---
// sticky ヘッダー＋SP（〜1024px）スライドダウンメニュー
import { Image } from 'astro:assets';
import logo from '../../assets/home/logo.png';
import { nav, phone } from '../../data/home';
import { u } from '../../lib/path';
---
<header class="site-header">
  <div class="inner">
    <a href={u('/')} class="logo-link" aria-label="FOCUS トップへ">
      <Image src={logo} alt="FOCUS" width={94} densities={[1, 2, 3]} class="logo" />
    </a>

    {/* PCナビ（>1024px） */}
    <nav class="pc-nav">
      {nav.map((n, i) => (
        <>
          {i > 0 && <span class="divider"></span>}
          <a class="nav-hov" href={`#${n.id}`}>{n.label}</a>
        </>
      ))}
    </nav>

    {/* ハンバーガー（≤1024px） */}
    <button class="hamburger" aria-label="メニュー" aria-expanded="false" data-menu-toggle>
      <span class="bars">
        <span class="bar bar-1"></span>
        <span class="bar bar-2"></span>
        <span class="bar bar-3"></span>
      </span>
      <span class="hb-label" data-menu-label>メニュー</span>
    </button>
  </div>
</header>

{/* SPメニュー（上からスライドダウン） */}
<div class="sp-menu" data-menu style="visibility:hidden">
  <div class="panel">
    <div class="items">
      {nav.map((n, i) => (
        <a href={`#${n.id}`} class="item" data-menu-close>
          {n.label}
          <svg width="8" height="13" viewBox="0 0 8 13" fill="none" stroke="#143778" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m1.5 1.5 5 5-5 5"></path></svg>
        </a>
      ))}
    </div>
    <div class="tel-wrap item">
      <a href={phone.tel} class="tel-block">
        <p class="tel-title">電話でのお問い合わせ</p>
        <span class="tel-num">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#E67832" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          {phone.display}
        </span>
        <p class="tel-hours">{phone.hours}</p>
      </a>
    </div>
  </div>
  <div class="backdrop" data-menu-close></div>
</div>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 50;
    background: rgba(255, 255, 255, .96);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid #E8EDF4;
  }
  .inner {
    max-width: 1280px; margin: 0 auto; height: 60px;
    display: flex; align-items: center; justify-content: space-between; padding: 0 20px;
  }
  .logo-link { display: flex; align-items: center; }
  .logo { height: 40px; width: auto; }

  .pc-nav { display: none; align-items: center; }
  .pc-nav a { font-size: 13.5px; font-weight: 500; color: var(--ink); text-decoration: none; margin: 0 24px; }
  .pc-nav a:first-child { margin-left: 0; }
  .pc-nav a:last-child { margin-right: 0; }
  .divider { width: 1px; height: 16px; background: #DDE3EA; }

  .hamburger {
    background: none; border: none; cursor: pointer; padding: 6px 8px; margin-right: -10px;
    display: flex; flex-direction: column; align-items: center; gap: 3px;
  }
  .bars { position: relative; width: 26px; height: 18px; display: block; }
  .bar {
    position: absolute; left: 0; width: 26px; height: 2.4px; border-radius: 2px; background: var(--navy);
    transition: top .25s, transform .25s, opacity .2s; transform-origin: center;
  }
  .bar-1 { top: 0; }
  .bar-2 { top: 8px; }
  .bar-3 { top: 16px; }
  .hb-label {
    font-size: 10px; font-weight: 700; letter-spacing: .08em; color: var(--navy);
    line-height: 1; margin-top: 3px; min-width: 38px; text-align: center; display: block;
  }
  :global(body.menu-open) .bar-1 { top: 8px; transform: rotate(45deg); }
  :global(body.menu-open) .bar-2 { opacity: 0; }
  :global(body.menu-open) .bar-3 { top: 8px; transform: rotate(-45deg); }

  .sp-menu { position: fixed; top: 60px; left: 0; right: 0; bottom: 0; z-index: 49; pointer-events: none; }
  .panel {
    background: #fff; border-bottom: 2px solid var(--navy);
    padding: 8px 24px 24px; box-shadow: 0 12px 30px rgba(20, 55, 120, .12);
    transform: translateY(-105%); transition: transform .25s cubic-bezier(.65, 0, .35, 1);
    position: relative; z-index: 1;
  }
  .items { display: flex; flex-direction: column; }
  .items .item {
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
    font-size: 15px; font-weight: 700; color: var(--ink); text-decoration: none;
    cursor: pointer; padding: 15px 2px; border-bottom: 1px solid #D8DFE8;
  }
  .tel-wrap { margin-top: 14px; display: flex; justify-content: center; }
  .tel-block {
    display: block; min-width: 250px; text-align: center; text-decoration: none;
    border: 2px solid var(--navy); border-radius: 12px; padding: 9px 20px 8px;
  }
  .tel-block:active { opacity: .6; }
  .tel-title { font-size: 12px; font-weight: 700; color: var(--ink); margin: 0; }
  .tel-num {
    display: inline-flex; align-items: center; justify-content: center; gap: 7px; margin-top: 2px; color: var(--navy);
    font-family: var(--font-tel); font-size: 20px; font-weight: 800; letter-spacing: .02em;
  }
  .tel-hours { font-size: 12px; color: var(--muted); margin: 2px 0 0; }
  .backdrop {
    position: absolute; inset: 0; background: rgba(10, 20, 40, .35);
    opacity: 0; transition: opacity .45s ease;
  }
  :global(body.menu-open) .sp-menu { pointer-events: auto; }
  :global(body.menu-open) .panel { transform: translateY(0); }
  :global(body.menu-open) .backdrop { opacity: 1; }

  @media (min-width: 1025px) {
    .pc-nav { display: flex; }
    .hamburger, .sp-menu { display: none; }
  }
</style>

<script>
  const toggle = document.querySelector('[data-menu-toggle]');
  const label = document.querySelector('[data-menu-label]');

  function setMenu(open: boolean) {
    document.body.classList.toggle('menu-open', open);
    toggle?.setAttribute('aria-expanded', String(open));
    if (label) label.textContent = open ? 'とじる' : 'メニュー';
  }

  toggle?.addEventListener('click', () => setMenu(!document.body.classList.contains('menu-open')));
  document.querySelectorAll('[data-menu-close]').forEach((el) => {
    el.addEventListener('click', () => setMenu(false));
  });
  // PC幅に戻ったら閉じる
  window.addEventListener('resize', () => {
    if (window.innerWidth > 1024) setMenu(false);
  });
</script>
