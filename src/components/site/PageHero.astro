---
// 下層ページの見出しバンド: 英字ラベル → h1（黄色蛍光ペンSVG）→ リード文（任意）
interface Props { eyebrow: string; title: string; lead?: string }
const { eyebrow, title, lead } = Astro.props;
---
<div class="page-hero">
  <p class="eyebrow">{eyebrow}</p>
  <h1>
    <span class="title-wrap">
      {title}
      <svg viewBox="0 0 400 22" preserveAspectRatio="none" aria-hidden="true">
        <path d="M4 8 Q 120 2 396 6 L 392 16 Q 180 13 8 17 Z" fill="#FFD84D" opacity="0.9"></path>
      </svg>
    </span>
  </h1>
  {lead && <p class="lead" set:html={lead} />}
</div>

<style>
  .page-hero {
    text-align: center; background: var(--alt-bg);
    padding: clamp(36px, 5.5vw, 56px) 24px;
  }
  .eyebrow {
    font: 800 clamp(11px, 1.3vw, 13px) var(--font-round);
    color: var(--orange-shadow); letter-spacing: .32em; margin: 0 0 6px;
  }
  h1 { font-family: var(--font-round); font-weight: 900; font-size: clamp(25px, 4vw, 34px); margin: 0; color: var(--ink); }
  .title-wrap { display: inline-block; position: relative; padding: 0 6px; z-index: 0; }
  .title-wrap svg {
    position: absolute; left: -8px; bottom: 0;
    width: calc(100% + 16px); height: 19px; z-index: -1;
  }
  .lead { font-size: 15px; line-height: 2; color: var(--ink); margin: 14px auto 0; max-width: 620px; }
</style>
