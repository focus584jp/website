---
// 下層ページの見出しバンド: 英字ラベル → h1（黄色蛍光ペンSVG）→ リード文（任意）
// 「ノートの1ページ」モチーフ: 方眼地＋ページ内容にちなんだ線画アイコン2つ（左上・右下の定位置）
// deco: study=鉛筆＋ノート（既定） / faq=？と！の吹き出し / price=¥コイン＋電卓 / company=ビル＋旗
// リード文はページ次第（フォーム系=安心材料として載せる／内容が直下と重複するページ=省略）
import flagLine from '../../assets/focus-flag-line.svg?raw'; // FOCUS旗ロゴの線画（design-system/assets/logo が正本）

interface Props { eyebrow: string; title: string; lead?: string; deco?: 'study' | 'faq' | 'price' | 'company' | 'classroom' }
const { eyebrow, title, lead, deco = 'study' } = Astro.props;
---
<div class="page-hero">
  {deco === 'study' && (
    <>
      {/* 見開きのノート（ページの膨らみ・罫線。左3本/右2本で書きかけの表情） */}
      <svg class="deco deco-tl deco-note" viewBox="0 0 28 26" fill="none" stroke="#4A7ACC" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14 20.8 C11 18.6 7.5 18 3.5 19 V4.6 C7.5 3.6 11 4.2 14 6.2 Z"></path>
        <path d="M14 20.8 C17 18.6 20.5 18 24.5 19 V4.6 C20.5 3.6 17 4.2 14 6.2 Z"></path>
        <path d="M3.2 20.6 C8 19.6 11.5 20.2 14 22.3 C16.5 20.2 20 19.6 24.8 20.6"></path>
        <path d="M6.2 9 C8.2 8.4 10 8.3 11.6 8.7 M6.2 12 C8.2 11.4 10 11.3 11.6 11.7 M6.2 15 C8.2 14.4 10 14.3 11.6 14.7"></path>
        <path d="M16.4 8.7 C18 8.3 19.8 8.4 21.8 9 M16.4 11.7 C18 11.3 19.8 11.4 21.8 12"></path>
      </svg>
      {/* 鉛筆（ボディの一本線＋塗りの芯。軸45度） */}
      <svg class="deco deco-br deco-pencil" viewBox="0 0 24 24" fill="none" stroke="#4A7ACC" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5.66 14.66 L14.66 5.66 L18.34 9.34 L9.34 18.34 Z"></path><path d="M8.4 15.6 L15.6 8.4"></path><path d="M5.66 14.66 L4 20 L9.34 18.34"></path><path d="M4 20 L4.7 17.75 L6.25 19.3 Z" fill="#4A7ACC" stroke="none"></path></svg>
    </>
  )}
  {deco === 'faq' && (
    <>
      {/* 「？」の丸吹き出し */}
      <svg class="deco deco-tl" viewBox="0 0 24 24" fill="none" stroke="#4A7ACC" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"></path><path d="M9.6 9.2 a2.5 2.5 0 0 1 4.86.83 c0 1.67-2.5 2.5-2.5 2.5"></path><path d="M12 15.6h.01"></path></svg>
      {/* 「！」の角吹き出し */}
      <svg class="deco deco-br" viewBox="0 0 24 24" fill="none" stroke="#4A7ACC" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path><path d="M12 6.6v4.6"></path><path d="M12 14.4h.01"></path></svg>
    </>
  )}
  {deco === 'price' && (
    <>
      {/* ¥コイン */}
      <svg class="deco deco-tl" viewBox="0 0 24 24" fill="none" stroke="#4A7ACC" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"></circle><path d="M8.8 7.5 12 11.7 15.2 7.5"></path><path d="M12 11.7 V17"></path><path d="M9.2 13h5.6"></path><path d="M9.2 15.4h5.6"></path></svg>
      {/* 電卓 */}
      <svg class="deco deco-br" viewBox="0 0 24 24" fill="none" stroke="#4A7ACC" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="16" height="20" x="4" y="2" rx="2"></rect><line x1="8" x2="16" y1="6" y2="6"></line><line x1="16" x2="16" y1="14" y2="18"></line><path d="M16 10h.01"></path><path d="M12 10h.01"></path><path d="M8 10h.01"></path><path d="M12 14h.01"></path><path d="M8 14h.01"></path><path d="M12 18h.01"></path><path d="M8 18h.01"></path></svg>
    </>
  )}
  {deco === 'classroom' && (
    <>
      {/* 地図ピン */}
      <svg class="deco deco-tl" viewBox="0 0 24 24" fill="none" stroke="#4A7ACC" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>
      {/* 電車 */}
      <svg class="deco deco-br" viewBox="0 0 24 24" fill="none" stroke="#4A7ACC" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="16" height="16" x="4" y="3" rx="2"></rect><path d="M4 11h16"></path><path d="M12 3v8"></path><path d="m8 19-2 3"></path><path d="m18 22-2-3"></path><path d="M8 15h.01"></path><path d="M16 15h.01"></path></svg>
    </>
  )}
  {deco === 'company' && (
    <>
      {/* ビル */}
      <svg class="deco deco-tl" viewBox="0 0 24 24" fill="none" stroke="#4A7ACC" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"></path><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"></path><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"></path><path d="M10 6h4"></path><path d="M10 10h4"></path><path d="M10 14h4"></path><path d="M10 18h4"></path></svg>
      {/* FOCUS旗ロゴの線画（実ロゴ。色はCSSのcurrentColorで統一） */}
      <span class="deco deco-br deco-flag" aria-hidden="true" set:html={flagLine} />
    </>
  )}
  <p class="eyebrow">{eyebrow}</p>
  <h1>
    <span class="title-wrap">
      {title}
      <svg viewBox="0 0 400 22" preserveAspectRatio="none" aria-hidden="true">
        <path d="M4 8 Q 120 2 396 6 L 392 16 Q 180 13 8 17 Z" fill="#FFD84D" opacity="0.9"></path>
      </svg>
    </span>
  </h1>
  {lead && <p class="lead" set:html={lead} />}
</div>

<style>
  .page-hero {
    position: relative; overflow: hidden; text-align: center;
    background-color: var(--alt-bg);
    /* 方眼ノート地（リング綴じは2026-07-10に検討の上で不採用） */
    background-image:
      linear-gradient(rgba(74, 122, 204, .08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(74, 122, 204, .08) 1px, transparent 1px);
    background-size: 22px 22px;
    padding: clamp(38px, 6vw, 58px) 24px clamp(36px, 5.5vw, 56px);
  }

  /* テーマアイコンの線画（うっすら。左上・右下の定位置） */
  .deco { position: absolute; opacity: .32; width: 54px; height: 54px; }
  /* 位置は中央からの距離で決める（PCでもタイトルとの間隔がスマホと同じに保たれる） */
  .deco-tl { left: calc(50% - min(43vw, 218px)); top: 14px; transform: rotate(-8deg); }
  .deco-br { right: calc(50% - min(44vw, 228px)); bottom: 10px; transform: rotate(8deg); }
  .deco-note { width: 58px; height: 54px; }
  .deco-flag { color: #4A7ACC; width: 52px; height: 64px; }
  .deco-flag :global(svg) { width: 100%; height: 100%; display: block; }
  .deco-flag :global(path) { stroke-width: 2.4; } /* non-scaling-strokeなので実px指定 */
  .deco-pencil { width: 68px; height: 68px; bottom: 8px; transform: rotate(0deg); } /* 軸45度 */

  .eyebrow {
    font: 800 clamp(11px, 1.3vw, 13px) var(--font-round);
    color: var(--orange); letter-spacing: .32em; margin: 0 0 6px;
  }
  h1 { font-family: var(--font-round); font-weight: 900; font-size: clamp(25px, 4vw, 34px); margin: 0; color: var(--ink); }
  .title-wrap { display: inline-block; position: relative; padding: 0 6px; z-index: 0; }
  .title-wrap svg {
    position: absolute; left: -8px; bottom: 0;
    width: calc(100% + 16px); height: 19px; z-index: -1;
  }
  .lead { font-size: 15px; line-height: 2; color: var(--ink); margin: 14px auto 0; max-width: 620px; }
</style>
