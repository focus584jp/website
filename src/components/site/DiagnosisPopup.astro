---
// 相性診断ポップアップ — ヒーロー通過後に表示（SP: 右下から / PC: 左下から）
// ×で閉じたらセッション中は再表示しない（sessionStorage）
// CTAはページ遷移せず、その場でモーダル（DiagnosisApp）を開く
import DiagnosisApp from './DiagnosisApp.astro';
---
<div class="diag-popup" data-diag-popup style="visibility:hidden">
  <button class="close" aria-label="とじる" data-diag-close>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 5l14 14"></path><path d="M19 5L5 19"></path></svg>
  </button>
  <div class="body">
    <span class="icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#333333" stroke-width="2.4" stroke-linecap="round"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path></svg></span>
    <div class="text">
      <div class="vs-row">
        <span class="chip group">集団指導？</span>
        <span class="vs">vs</span>
        <span class="chip solo">個別指導？</span>
      </div>
      <p>うちの子に合う塾は、<span class="mk">どのタイプ？</span></p>
    </div>
  </div>
  <button type="button" class="go" data-diag-open>30秒でわかる塾タイプ診断 →</button>
</div>

{/* 診断モーダル（ポップアップのCTAから開く） */}
<div class="diag-modal" data-diag-modal>
  <div class="dm-ov" data-dm-close></div>
  <div class="dm-sheet" role="dialog" aria-modal="true" aria-label="塾タイプ診断">
    <button type="button" class="dm-x" data-dm-close aria-label="閉じる">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 5l14 14"></path><path d="M19 5L5 19"></path></svg>
    </button>
    <DiagnosisApp />
  </div>
</div>

<style>
  .diag-popup {
    position: fixed; right: 14px; left: auto; bottom: 96px; z-index: 55; width: 300px;
    background: #fff; border: 2px solid var(--navy); border-radius: 16px;
    box-shadow: 4px 5px 0 rgba(20, 55, 120, .15); padding: 16px 16px 14px;
    transform: translateX(120%) rotate(-2.5deg); opacity: 0; pointer-events: none;
    transition: transform .4s ease, opacity .4s ease; box-sizing: border-box;
  }
  @media (min-width: 1025px) {
    .diag-popup { left: 18px; right: auto; bottom: 22px; transform: translateX(-120%) rotate(-2.5deg); }
  }
  :global(body.past-hero) .diag-popup:not(.closed) {
    transform: translateX(0) rotate(-2.5deg); opacity: 1; pointer-events: auto;
  }
  /* ×は右上に浮かせて明示（白丸＋紺枠） */
  .close {
    position: absolute; top: -12px; right: -10px; width: 30px; height: 30px;
    background: #fff; border: 2px solid var(--navy); border-radius: 50%;
    color: var(--navy); cursor: pointer; display: grid; place-items: center; padding: 0;
    box-shadow: 0 2px 6px rgba(20, 42, 84, .2);
  }
  .body { display: flex; align-items: center; gap: 10px; }
  .icon {
    flex: none; width: 36px; height: 36px; border-radius: 50%;
    background: #FFF8E1; border: 2px dashed #E6C94A; display: grid; place-items: center;
  }
  .text { display: flex; flex-direction: column; gap: 6px; min-width: 0; align-items: flex-start; }
  .vs-row { display: flex; align-items: center; gap: 6px; }
  .chip { font-family: var(--font-round); font-size: 12px; font-weight: 900; border-radius: 999px; padding: 3px 10px; white-space: nowrap; }
  .chip.group { color: var(--navy); background: var(--blue-pale); }
  .chip.solo { color: var(--orange-shadow); background: #FBDECB; }
  .vs { font: 900 12px var(--font-round); color: var(--gray-1); }
  .text p { font-family: var(--font-round); font-size: 14px; font-weight: 900; color: var(--ink); margin: 0; line-height: 1.6; }
  .text .mk { white-space: nowrap; } /* 「どのタイプ？」の途中で折り返さない */
  .go {
    display: flex; align-items: center; justify-content: center; gap: 6px; width: 100%;
    background: var(--navy); color: #fff; font-size: 14.5px; font-weight: 700; padding: 13px;
    border-radius: 999px; text-decoration: none; margin-top: 12px; box-shadow: 0 3px 0 var(--navy-shadow);
    border: none; cursor: pointer; font-family: var(--font-body);
  }

  /* 診断モーダル */
  .diag-modal {
    position: fixed; inset: 0; z-index: 120; padding: 14px;
    display: none; align-items: center; justify-content: center;
  }
  .diag-modal.is-open { display: flex; }
  .dm-ov { position: absolute; inset: 0; background: rgba(16, 24, 34, .6); animation: dm-fade .25s ease; }
  .dm-sheet {
    position: relative; width: 100%; max-width: 560px;
    max-height: calc(100dvh - 28px); overflow-y: auto; -webkit-overflow-scrolling: touch;
    background: #fff; border-radius: 18px; box-shadow: 0 20px 50px rgba(0, 0, 0, .35);
    animation: dm-zoom .25s ease;
  }
  .dm-x {
    position: sticky; top: 10px; margin-left: auto; margin-right: 10px; z-index: 2;
    width: 32px; height: 32px; background: #fff; border: 2px solid var(--navy); border-radius: 50%;
    color: var(--navy); cursor: pointer; display: grid; place-items: center; padding: 0;
    box-shadow: 0 2px 6px rgba(20, 42, 84, .2);
  }
  /* モーダル内はシート自体を1枚のカードとして使う: 内側カードの枠・影・角丸を外して
     「カード in カード」の二重枠を解消し、横幅を広く使う（/diagnosis 単体ページは従来どおり） */
  .dm-sheet :global(.stage) { background: #fff; min-height: auto; padding: 0 0 10px; }
  .dm-sheet :global(.card) { border: none; box-shadow: none; border-radius: 0; }
  .dm-sheet :global(.intro-card) { padding: 18px 22px 34px; }
  .dm-sheet :global(.quiz-head) { margin: 2px 0 14px; padding: 0 54px 0 22px; } /* 右は✕ボタンを避ける */
  .dm-sheet :global(.quiz-card) { padding: 20px 22px 28px; }
  .dm-sheet :global(.back) { margin-bottom: 8px; }
  .dm-sheet :global(.result-body) { padding: 26px 22px; }
  @keyframes dm-fade { from { opacity: 0; } }
  @keyframes dm-zoom { from { opacity: 0; transform: scale(.92); } }
</style>

<script>
  const popup = document.querySelector<HTMLElement>('[data-diag-popup]');
  const KEY = 'focus-diag-popup-closed';
  if (popup) {
    if (sessionStorage.getItem(KEY)) popup.classList.add('closed');
    popup.querySelector('[data-diag-close]')?.addEventListener('click', () => {
      popup.classList.add('closed');
      sessionStorage.setItem(KEY, '1');
    });
  }

  // 診断モーダルの開閉
  const modal = document.querySelector<HTMLElement>('[data-diag-modal]');
  if (modal) {
    const open = () => {
      // DEVで ?quiz= 指定時はリセットしない（?diag&quiz=n でモーダル内の設問/結果画面を直接確認するため）
      const keepDevState = import.meta.env.DEV && new URLSearchParams(location.search).has('quiz');
      if (!keepDevState) modal.querySelector('[data-diag-app]')?.dispatchEvent(new Event('diag-reset')); // 常に導入から
      modal.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      document.addEventListener('keydown', onKey);
    };
    const close = () => {
      modal.classList.remove('is-open');
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onKey);
    };
    function onKey(e: KeyboardEvent) { if (e.key === 'Escape') close(); }
    document.querySelector('[data-diag-open]')?.addEventListener('click', open);
    // DEV専用: ?diag でモーダルを自動オープン（本番ビルドでは除去される）
    if (import.meta.env.DEV && new URLSearchParams(location.search).has('diag')) open();
    modal.addEventListener('click', (e) => {
      if ((e.target as Element).closest('[data-dm-close]')) close();
    });
  }
</script>
