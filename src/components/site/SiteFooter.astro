---
// フッター — ロゴ＋見出しなしのリンクグリッド＋法務系の小リンク行＋©バンド
import { Image } from 'astro:assets';
import logo from '../../assets/home/logo.png';
import { u } from '../../lib/path';

const links = [
  { href: '/method', label: '指導方針' },
  { href: '/price', label: '料金' },
  { href: '/classrooms', label: '教室一覧' },
  { href: '/faq', label: 'よくあるご質問' },
  { href: '/diagnosis', label: '相性診断' },
  { href: '/request', label: '資料請求' },
  { href: '/consult', label: '無料相談' },
];
const legal = [
  { href: '/company', label: '会社概要' },
  { href: '/company#privacy', label: 'プライバシーポリシー' },
];
---
<footer class="site-footer">
  <div class="inner">
    <div class="brand">
      <Image src={logo} alt="FOCUS" width={80} densities={[1, 2, 3]} class="logo" />
      <p>勉強が苦手な中学生専門の個別指導塾</p>
    </div>
    <nav class="links" aria-label="フッターナビ">
      {links.map((l) => <a href={u(l.href)}>{l.label}</a>)}
    </nav>
    <div class="legal">
      {legal.map((l) => <a href={u(l.href)}>{l.label}</a>)}
    </div>
  </div>
  <div class="copyright"><p>© 2026 FOCUS, Inc.</p></div>
  <div class="sp-spacer" aria-hidden="true"></div>
</footer>

<style>
  .site-footer { background: var(--panel); }
  .inner {
    max-width: 1200px; margin: 0 auto; padding: 40px 24px 28px;
    display: flex; flex-direction: column; gap: 24px;
  }
  .brand { display: flex; flex-direction: column; align-items: flex-start; gap: 12px; }
  .logo { height: 34px; width: auto; }
  .brand p { font-size: 13px; color: var(--muted); margin: 0; }

  .links { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px 24px; max-width: 420px; }
  .links a { font-size: 13.5px; font-weight: 500; color: var(--ink); text-decoration: none; transition: color .2s; }
  .links a:hover { color: var(--navy); }

  .legal {
    display: flex; flex-wrap: wrap; gap: 8px 20px;
    border-top: 1px solid var(--line); padding-top: 18px;
  }
  .legal a { font-size: 12px; color: var(--gray-1); text-decoration: none; transition: color .2s; }
  .legal a:hover { color: var(--navy); }

  @media (min-width: 768px) {
    .links { grid-template-columns: repeat(4, auto); max-width: none; justify-content: start; gap: 14px 36px; }
  }

  .copyright { background: var(--navy); }
  .copyright p { margin: 0; padding: 16px 24px; font-size: 12px; color: #C9D6EE; text-align: center; }
  .sp-spacer { height: 76px; }
  @media (min-width: 1025px) { .sp-spacer { display: none; } }
  :global(body.no-fixed-cta) .sp-spacer { display: none; }
</style>
